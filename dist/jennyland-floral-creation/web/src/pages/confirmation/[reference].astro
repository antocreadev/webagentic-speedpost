---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { api, safe, type Order } from "@/lib/api";
import { formatEur, formatDateFr } from "@/lib/format";

const { reference } = Astro.params;
if (!reference) return Astro.redirect("/");

const { data } = await safe(api.order(reference), null as Order | null);
const order = data;
const whatsapp = (import.meta.env.PUBLIC_WHATSAPP as string) || "+33600000000";
---

<BaseLayout title={`Commande ${reference} — Jennyland`}>
  <section class="bath bath-rose-deep section">
    <div class="mx-auto max-w-[1000px] text-center">
      <span class="spec-num text-cream/60 mb-6 block">Confirmation · {reference}</span>
      <h1 class="font-display text-display-xl text-cream leading-[0.9]" data-reveal>
        Merci de tout cœur,<br/>
        <span class="cursive text-blush">{order?.customer_first_name || ""}.</span>
      </h1>
      <p class="mt-10 font-display-italic text-2xl text-cream/90 max-w-2xl mx-auto leading-tight" data-reveal style="--reveal-delay: 150ms">
        Votre commande est arrivée chez Jenny. Vous recevez un email de confirmation, et un message WhatsApp dès que votre bouquet sort de l'atelier.
      </p>
    </div>
  </section>

  {order && (
    <section class="bath bath-cream section">
      <div class="mx-auto max-w-[1000px]">
        <div class="grid grid-cols-12 gap-6 md:gap-8 mb-12 border-t border-ink pt-8">
          <div class="col-span-6 md:col-span-3">
            <span class="spec-num text-ink-40">Statut</span>
            <div class="font-display text-2xl text-ink mt-2">{order.status === "paid" ? "Payée" : order.status}</div>
            {order.paid_at && <p class="text-xs text-ink-60 mt-1">{formatDateFr(order.paid_at)}</p>}
          </div>
          <div class="col-span-6 md:col-span-3">
            <span class="spec-num text-ink-40">Sous-total</span>
            <div class="font-display text-2xl text-ink mt-2">{formatEur(order.subtotal_cents)}</div>
          </div>
          <div class="col-span-6 md:col-span-3">
            <span class="spec-num text-ink-40">Livraison</span>
            <div class="font-display text-2xl text-ink mt-2">
              {order.shipping_cents === 0 ? "Offerte" : formatEur(order.shipping_cents)}
            </div>
          </div>
          <div class="col-span-6 md:col-span-3">
            <span class="spec-num text-rose-deep">Total</span>
            <div class="font-display text-3xl text-rose-deep mt-2">{formatEur(order.total_cents)}</div>
          </div>
        </div>

        <span class="spec-num text-ink-40 mb-6 block">Articles</span>
        <ul class="border-t border-ink">
          {order.items.map((item, i) => (
            <li class="grid grid-cols-12 gap-4 py-5 border-b border-line items-baseline">
              <span class="col-span-1 spec-num text-ink-40">N° 0{(i + 1).toString().padStart(2, "0")}</span>
              <div class="col-span-7">
                <div class="font-display text-xl text-ink">{item.name}</div>
                <div class="text-xs text-ink-60 mt-1">× {item.qty}</div>
              </div>
              <div class="col-span-4 text-right">
                <div class="text-sm text-ink-60">{formatEur(item.unit_price_cents)}</div>
                <div class="font-display text-xl text-ink">{formatEur(item.total_cents)}</div>
              </div>
            </li>
          ))}
        </ul>

        <div class="mt-12 grid grid-cols-12 gap-6 md:gap-8 items-end">
          <div class="col-span-12 md:col-span-7">
            <h3 class="font-display text-display-m text-ink leading-[0.92]">
              Et <span class="font-display-italic text-rose-deep">maintenant ?</span>
            </h3>
            <ol class="mt-6 space-y-2 text-sm text-ink-80 max-w-md">
              <li>1. Jenny prépare votre commande dans les jours qui viennent.</li>
              <li>2. Vous recevez un message dès qu'elle commence (sous 48h).</li>
              <li>3. Suivi photo Instagram ou WhatsApp à votre demande.</li>
              <li>4. Livraison sous 2-3 jours après finition.</li>
            </ol>
          </div>
          <div class="col-span-12 md:col-span-5 md:text-right">
            <a
              href={`https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(`Bonjour Jenny, c'est au sujet de la commande ${reference}.`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary"
            >
              Contacter Jenny sur WhatsApp →
            </a>
          </div>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
