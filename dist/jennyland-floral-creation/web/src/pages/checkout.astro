---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Checkout from "@/islands/Checkout";

const paypalClientId = (import.meta.env.PUBLIC_PAYPAL_CLIENT_ID as string) || "sb";
---

<BaseLayout title="Paiement — Jennyland">
  <section class="bath bath-rose-soft pt-12 pb-12 px-5 sm:px-8 md:px-12">
    <div class="mx-auto max-w-[1200px]">
      <nav class="spec-num text-ink-40 mb-12">
        <a href="/" class="hover:text-rose-deep">Accueil</a>
        <span class="opacity-50 mx-2">/</span>
        <a href="/panier" class="hover:text-rose-deep">Panier</a>
        <span class="opacity-50 mx-2">/</span>
        <span>Paiement</span>
      </nav>
      <span class="spec-num text-ink-40 mb-6 block">N° XI · Paiement sécurisé</span>
      <h1 class="font-display text-display-xl text-ink leading-[0.9]">
        On y est <span class="font-display-italic text-rose-deep">presque.</span>
      </h1>
    </div>
  </section>

  <section class="bath bath-cream section">
    <div class="mx-auto max-w-[1200px]">
      <Checkout client:only="react" paypalClientId={paypalClientId} />
    </div>
  </section>

  <script
    is:inline
    define:vars={{ paypalClientId }}
    src={`https://www.paypal.com/sdk/js?client-id=${paypalClientId}&currency=EUR&intent=capture&locale=fr_FR`}
  ></script>
</BaseLayout>
