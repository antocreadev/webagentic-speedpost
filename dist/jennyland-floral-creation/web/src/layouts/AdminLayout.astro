---
import "@/styles/global.css";

interface Props {
  title?: string;
  active?: string;
  noShell?: boolean;
}
const { title = "Admin — Jennyland", active = "", noShell = false } = Astro.props;
const links = [
  { href: "/admin", label: "Accueil", key: "home" },
  { href: "/admin/produits", label: "Produits", key: "products" },
  { href: "/admin/categories", label: "Catégories", key: "categories" },
  { href: "/admin/unitaires", label: "Fleurs unitaires", key: "items" },
  { href: "/admin/commandes", label: "Commandes", key: "orders" },
  { href: "/admin/contenu", label: "Contenu", key: "content" },
  { href: "/admin/parametres", label: "Paramètres", key: "settings" },
];
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="robots" content="noindex,nofollow" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Pinyon+Script&family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
  />
</head>
<body class="min-h-screen bg-rose-soft admin-shell">
  {noShell ? (
    <slot />
  ) : (
    <div class="flex min-h-screen">
      <aside class="hidden md:flex md:w-64 lg:w-72 flex-col bath bath-ink p-6 sticky top-0 max-h-screen overflow-y-auto">
        <a href="/admin" class="flex items-baseline gap-2 mb-12">
          <span class="cursive text-3xl text-blush leading-none">Jennyland</span>
          <span class="spec-num opacity-50">Admin</span>
        </a>

        <nav class="flex-1 space-y-1">
          {links.map((link) => (
            <a
              href={link.href}
              class={`flex items-center gap-3 px-3 py-2.5 text-[13px] transition-colors ${
                active === link.key ? "bg-blush text-ink font-semibold" : "text-cream/80 hover:text-blush"
              }`}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <div class="mt-6 pt-6 border-t border-cream/10 space-y-2">
          <a href="/" class="flex items-center gap-2 text-[11px] text-cream/50 hover:text-blush py-1.5 uppercase tracking-widest" target="_blank" rel="noopener">
            ↗ Voir le site public
          </a>
          <button id="admin-logout" class="flex items-center gap-2 text-[11px] text-cream/50 hover:text-rose-deep py-1.5 w-full text-left uppercase tracking-widest">
            ← Se déconnecter
          </button>
        </div>
      </aside>

      <div class="flex-1 min-w-0 px-5 sm:px-8 py-8 md:py-12">
        <slot />
      </div>
    </div>
  )}

  <script>
    document.documentElement.classList.add("js-ready");
    document.getElementById("admin-logout")?.addEventListener("click", async () => {
      try {
        await fetch(`${import.meta.env.PUBLIC_API_URL || "http://127.0.0.1:8787"}/auth/logout`, {
          method: "POST",
          credentials: "include",
        });
      } catch {}
      window.location.href = "/admin/login";
    });
  </script>
</body>
</html>
