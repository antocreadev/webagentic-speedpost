---
interface Props { class?: string; }
const { class: className = "" } = Astro.props;
---
<div class={`${className}`} aria-hidden="true">
  <div class="aspect-square rounded-xl shimmer"></div>
  <div class="mt-3 h-4 w-2/3 shimmer rounded"></div>
  <div class="mt-2 h-3 w-1/3 shimmer rounded"></div>
  <div class="mt-3 h-3 w-1/4 shimmer rounded"></div>
</div>
