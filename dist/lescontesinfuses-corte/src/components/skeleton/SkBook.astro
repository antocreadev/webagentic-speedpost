---
interface Props { class?: string; }
const { class: className = "" } = Astro.props;
---
<div class={`group ${className}`} aria-hidden="true">
  <div class="aspect-[2/3] rounded-sm shimmer shadow-book"></div>
  <div class="mt-4 h-3.5 w-3/4 shimmer rounded"></div>
  <div class="mt-2 h-3 w-1/2 shimmer rounded"></div>
  <div class="mt-3 h-3 w-1/3 shimmer rounded"></div>
</div>
