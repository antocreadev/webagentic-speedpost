---
interface Props { class?: string; }
const { class: className = "" } = Astro.props;
---
<div class={`flex gap-5 p-5 rounded-xl border border-line bg-cream-50/60 ${className}`} aria-hidden="true">
  <div class="shrink-0 w-16 h-20 shimmer rounded-md"></div>
  <div class="flex-1 space-y-2.5">
    <div class="h-3 w-24 shimmer rounded"></div>
    <div class="h-5 w-3/4 shimmer rounded"></div>
    <div class="h-3 w-1/2 shimmer rounded"></div>
    <div class="h-3 w-2/3 shimmer rounded"></div>
  </div>
</div>
