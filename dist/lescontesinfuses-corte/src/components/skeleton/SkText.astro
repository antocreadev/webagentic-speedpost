---
interface Props { lines?: number; class?: string; }
const { lines = 3, class: className = "" } = Astro.props;
const widths = ["w-full", "w-11/12", "w-5/6", "w-3/4", "w-2/3"];
---
<div class={`space-y-2.5 ${className}`} aria-hidden="true">
  {Array.from({ length: lines }).map((_, i) => (
    <div class={`h-3 shimmer rounded ${widths[i % widths.length]}`}></div>
  ))}
</div>
