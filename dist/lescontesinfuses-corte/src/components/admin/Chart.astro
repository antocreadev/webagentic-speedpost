---
interface Props {
  type: "bar" | "line" | "sparkline";
  data: number[];
  labels?: string[];
  height?: number;
  color?: string;
  className?: string;
}
const { type, data, labels = [], height = 180, color = "#C77A4F", className = "" } = Astro.props as Props;

const w = 600;
const padX = 8;
const padY = 12;
const innerW = w - padX * 2;
const innerH = height - padY * 2;
const max = Math.max(...data, 1);
const min = type === "line" ? Math.min(...data) : 0;
const range = max - min || 1;

let linePath = "";
let areaPath = "";
if ((type === "line" || type === "sparkline") && data.length > 1) {
  const points = data.map((v, i) => {
    const x = padX + (i / (data.length - 1)) * innerW;
    const y = padY + (1 - (v - min) / range) * innerH;
    return [x, y];
  });
  linePath = points.map((p, i) => `${i === 0 ? "M" : "L"}${p[0].toFixed(1)} ${p[1].toFixed(1)}`).join(" ");
  areaPath = `${linePath} L ${padX + innerW} ${padY + innerH} L ${padX} ${padY + innerH} Z`;
}

const barW = data.length ? innerW / data.length - 4 : 0;
const gradId = `g-${Math.random().toString(36).slice(2, 7)}`;
const isSpark = type === "sparkline";
---
<div class:list={[className, "relative w-full"]}>
  <svg viewBox={`0 0 ${w} ${height}`} class="w-full" style={`height:${height}px`} preserveAspectRatio="none" aria-hidden="true">
    <defs>
      <linearGradient id={gradId} x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color={color} stop-opacity="0.25" />
        <stop offset="100%" stop-color={color} stop-opacity="0" />
      </linearGradient>
    </defs>
    {!isSpark && (
      <>
        <line x1={padX} x2={w - padX} y1={padY} y2={padY} stroke="#EAD9A6" stroke-width="0.5" stroke-dasharray="2 4" />
        <line x1={padX} x2={w - padX} y1={padY + innerH / 2} y2={padY + innerH / 2} stroke="#EAD9A6" stroke-width="0.5" stroke-dasharray="2 4" />
        <line x1={padX} x2={w - padX} y1={padY + innerH} y2={padY + innerH} stroke="#D9C8A8" stroke-width="0.8" />
      </>
    )}
    {type === "bar" && data.map((v, i) => (
      <rect
        x={padX + i * (innerW / data.length) + 2}
        y={padY + (1 - v / max) * innerH}
        width={barW}
        height={(v / max) * innerH}
        rx="2"
        fill={color}
        opacity="0.85"
      />
    ))}
    {(type === "line" || type === "sparkline") && (
      <>
        <path d={areaPath} fill={`url(#${gradId})`} />
        <path d={linePath} fill="none" stroke={color} stroke-width={isSpark ? 1.5 : 2} stroke-linecap="round" stroke-linejoin="round" />
        {!isSpark && data.map((v, i) => {
          const x = padX + (i / (data.length - 1)) * innerW;
          const y = padY + (1 - (v - min) / range) * innerH;
          return <circle cx={x} cy={y} r="2.5" fill="#FBF6E9" stroke={color} stroke-width="1.4" />;
        })}
      </>
    )}
  </svg>
  {labels.length > 0 && !isSpark && (
    <div class="mt-1.5 flex justify-between font-sans text-[10px] tabular-nums text-cocoa-400">
      {labels.map((l) => <span>{l}</span>)}
    </div>
  )}
</div>
