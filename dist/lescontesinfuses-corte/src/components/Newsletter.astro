---
import LaceMedallion from "./icons/LaceMedallion.astro";
interface Props { compact?: boolean; class?: string; }
const { compact = false, class: className = "" } = Astro.props;
---
<section class={`relative ${className}`}>
  <div class={`mx-auto ${compact ? "max-w-xl" : "max-w-2xl"} text-center`}>
    <div class="flex justify-center mb-4 opacity-80">
      <LaceMedallion size={120} />
    </div>
    <p class="eyebrow">Lettre saisonnière</p>
    <h3 class="font-display italic text-3xl md:text-4xl text-cocoa-600 mt-2">Recevez les coups de cœur du mois</h3>
    <p class="mt-3 text-cocoa-400 text-sm md:text-base">Et le calendrier des événements, glissé entre deux pages, une fois par mois. Pas plus.</p>
    <form class="js-newsletter-form mt-6 flex flex-col sm:flex-row gap-3 sm:items-stretch" data-newsletter>
      <label class="sr-only" for="nl-email">Votre email</label>
      <input id="nl-email" name="email" type="email" required placeholder="votre.email@exemple.fr"
        class="flex-1 px-5 py-3 rounded-full border border-line bg-paper text-cocoa-700 placeholder:text-cocoa-200 focus:outline-none focus:border-terracotta-400 font-sans text-sm" />
      <button type="submit" class="btn-terracotta justify-center">S'inscrire</button>
    </form>
    <label class="mt-3 flex items-start justify-center gap-2 text-xs text-cocoa-400 font-sans">
      <input type="checkbox" required class="mt-0.5 accent-terracotta-400" />
      <span>J'accepte de recevoir la lettre. Je peux me désinscrire à tout moment (RGPD).</span>
    </label>
  </div>
</section>

<script>
  import { subscribeNewsletter, apiError } from "@/lib/api";
  function bind(form: HTMLFormElement) {
    if ((form as any).__bound) return;
    (form as any).__bound = true;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const email = String(fd.get("email") ?? "").trim();
      if (!email) return;
      const btn = form.querySelector("button[type=submit]") as HTMLButtonElement | null;
      if (btn) btn.disabled = true;
      try {
        await subscribeNewsletter({ email, consent: true } as any);
        (window as any).__lciToast?.success("Inscription bientôt confirmée par email.");
        if (btn) btn.textContent = "Bien reçu, à très vite";
        form.reset();
      } catch (err) {
        const ee = await apiError(err);
        (window as any).__lciToast?.error("Inscription impossible", ee.message);
      } finally {
        if (btn) btn.disabled = false;
      }
    });
  }
  document.querySelectorAll<HTMLFormElement>("form[data-newsletter]").forEach(bind);
</script>
