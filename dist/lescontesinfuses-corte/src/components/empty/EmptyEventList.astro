---
import EmptyState from "./EmptyState.astro";
---
<EmptyState
  title="Pas d'événement à l'agenda"
  description="Le programme de la saison se prépare. Inscrivez-vous à la gazette pour le recevoir, glissé entre deux pages."
  ctaLabel="Recevoir la gazette"
  ctaHref="/newsletter"
  secondaryLabel="Voir le journal"
  secondaryHref="/journal"
>
  <div slot="icon">
    <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#7C4F31" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
      <line x1="9" y1="14" x2="15" y2="14" stroke="#C9A37D" stroke-dasharray="2 2"/>
    </svg>
  </div>
</EmptyState>
