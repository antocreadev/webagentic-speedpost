---
import EmptyState from "./EmptyState.astro";
import LaceMedallion from "@/components/icons/LaceMedallion.astro";
---
<EmptyState
  title="Encore vide, mais plein de promesses"
  description="Glissez ici un roman corse, un thé chaud, une bougie d'artisan. Le panier patiente, comme un libraire bienveillant."
  ctaLabel="Parcourir les livres"
  ctaHref="/livres"
  secondaryLabel="Voir la carte café"
  secondaryHref="/cafe"
>
  <div slot="icon" class="relative inline-flex items-center justify-center">
    <LaceMedallion size={150} />
    <svg class="absolute" width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="#7C4F31" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
      <line x1="3" y1="6" x2="21" y2="6"/>
      <path d="M16 10a4 4 0 0 1-8 0"/>
    </svg>
  </div>
</EmptyState>
