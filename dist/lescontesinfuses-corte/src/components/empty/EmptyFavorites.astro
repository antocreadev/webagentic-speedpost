---
import EmptyState from "./EmptyState.astro";
---
<EmptyState
  title="Pas encore de coups de cœur"
  description="Cliquez sur le marque-page d'un livre pour le retrouver ici, comme un signet glissé entre deux pages."
  ctaLabel="Voir les livres"
  ctaHref="/livres"
>
  <div slot="icon">
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#C77A4F" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
  </div>
</EmptyState>
