---
// Mobile bottom navigation, visible <md only.
// Hides on scroll-down, reappears on scroll-up. Active route gets terracotta pill.
const path = Astro.url.pathname;
function isActive(href: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
const items = [
  { href: "/", label: "Accueil", key: "home" },
  { href: "/livres", label: "Livres", key: "books" },
  { href: "/recherche", label: "Recherche", key: "search" },
  { href: "/panier", label: "Panier", key: "cart" },
  { href: "/compte", label: "Compte", key: "account" },
];
---
<nav
  id="lci-bottom-nav"
  aria-label="Navigation mobile"
  class="touch-only fixed inset-x-0 bottom-0 z-30 transition-transform duration-300 safe-bottom"
  data-hidden="false"
>
  <div class="bg-paper/85 backdrop-blur-xl border-t border-line">
    <ul class="grid grid-cols-5 max-w-md mx-auto px-2">
      {items.map((it) => {
        const active = isActive(it.href);
        return (
          <li class="flex">
            <a
              href={it.href}
              data-bn-key={it.key}
              aria-label={it.label}
              aria-current={active ? "page" : undefined}
              class={`flex-1 min-h-[64px] flex flex-col items-center justify-center gap-1 py-2 px-1 transition-colors ${active ? "text-terracotta-400" : "text-cocoa-600"}`}
            >
              <span class={`relative inline-flex items-center justify-center w-11 h-11 rounded-full transition-all duration-300 ${active ? "bg-terracotta-50" : "bg-transparent"}`}>
                {it.key === "home" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg>
                )}
                {it.key === "books" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                )}
                {it.key === "search" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                )}
                {it.key === "cart" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                )}
                {it.key === "account" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                )}
                {it.key === "cart" && (
                  <span data-bn-cart-count class="hidden absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] px-1 rounded-full bg-terracotta-400 text-cream-50 text-[10px] font-sans font-medium leading-[18px] text-center">0</span>
                )}
              </span>
              <span class="text-[10px] font-sans tracking-wide">{it.label}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</nav>

<script>
  function initBottomNav() {
    const nav = document.getElementById("lci-bottom-nav");
    if (!nav) return;
    let lastY = window.scrollY;
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        const dy = y - lastY;
        if (y > 80 && dy > 4) {
          nav.setAttribute("data-hidden", "true");
          nav.style.transform = "translateY(110%)";
        } else if (dy < -4 || y < 40) {
          nav.setAttribute("data-hidden", "false");
          nav.style.transform = "translateY(0)";
        }
        lastY = y;
        ticking = false;
      });
    };
    window.addEventListener("scroll", onScroll, { passive: true });

    // cart count
    try {
      const raw = localStorage.getItem("lci-cart-v1");
      const items = raw ? JSON.parse(raw) : [];
      const count = items.reduce((s: number, i: any) => s + (i.qty || 0), 0);
      const el = nav.querySelector<HTMLElement>("[data-bn-cart-count]");
      if (el && count > 0) {
        el.classList.remove("hidden");
        el.textContent = String(count);
      }
    } catch {}

    // Intercept cart click on mobile to open drawer
    const cartLink = nav.querySelector<HTMLAnchorElement>('[data-bn-key="cart"]');
    cartLink?.addEventListener("click", (e) => {
      if (window.innerWidth >= 768) return;
      e.preventDefault();
      window.dispatchEvent(new CustomEvent("lci:open-cart"));
    });
  }
  document.addEventListener("astro:page-load", initBottomNav);
  if (document.readyState !== "loading") initBottomNav();
  else document.addEventListener("DOMContentLoaded", initBottomNav);
</script>
