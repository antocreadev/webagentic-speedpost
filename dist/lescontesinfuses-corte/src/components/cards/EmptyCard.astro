---
interface Props {
  title?: string;
  message?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const {
  title = "Rien à infuser ici, pas encore",
  message = "Cette étagère attend ses livres, ses tasses et ses histoires. Revenez bientôt, le silence aussi se savoure.",
  ctaLabel,
  ctaHref,
} = Astro.props;
---
<div class="relative col-span-full mx-auto max-w-xl text-center px-6 py-12 bg-cream-50 border border-line rounded-2xl overflow-hidden">
  {/* Lace ornament top */}
  <svg class="absolute top-3 left-1/2 -translate-x-1/2 opacity-50" width="120" height="14" viewBox="0 0 120 14" fill="none" stroke="#C9A37D" stroke-width="0.7" aria-hidden="true">
    <path d="M0 7 Q 10 0, 20 7 T 40 7 T 60 7 T 80 7 T 100 7 T 120 7"/>
    <circle cx="60" cy="7" r="2" fill="#C9A37D" stroke="none"/>
  </svg>

  {/* Empty teapot illustration */}
  <svg class="mx-auto mt-2" width="84" height="64" viewBox="0 0 84 64" fill="none" stroke="#7C4F31" stroke-width="1.1" stroke-linecap="round" aria-hidden="true">
    <path d="M18 28 Q 18 18, 28 16 L 52 16 Q 62 18, 62 28 L 60 48 Q 58 56, 50 56 L 30 56 Q 22 56, 20 48 Z"/>
    <path d="M62 30 Q 72 30, 72 38 Q 72 46, 62 46"/>
    <path d="M40 16 L 40 10 Q 40 6, 44 6 Q 48 6, 48 10"/>
    <ellipse cx="40" cy="16" rx="16" ry="2" fill="#F2E7C4" stroke="none"/>
    <path d="M14 32 Q 18 30, 22 32" opacity=".5"/>
  </svg>

  <p class="eyebrow mt-4">Étagère vide</p>
  <h3 class="font-display italic text-2xl text-cocoa-600 mt-2 leading-tight">{title}</h3>
  <p class="font-body text-sm text-cocoa-400 mt-3 leading-relaxed">{message}</p>

  {ctaLabel && ctaHref && (
    <a href={ctaHref} class="btn-ghost mt-6 inline-flex">{ctaLabel}</a>
  )}

  {/* Lace ornament bottom */}
  <svg class="absolute bottom-3 left-1/2 -translate-x-1/2 opacity-50 rotate-180" width="120" height="14" viewBox="0 0 120 14" fill="none" stroke="#C9A37D" stroke-width="0.7" aria-hidden="true">
    <path d="M0 7 Q 10 0, 20 7 T 40 7 T 60 7 T 80 7 T 100 7 T 120 7"/>
    <circle cx="60" cy="7" r="2" fill="#C9A37D" stroke="none"/>
  </svg>
</div>
