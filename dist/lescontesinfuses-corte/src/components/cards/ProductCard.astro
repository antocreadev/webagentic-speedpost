---
import { formatPrice } from "@/lib/format";
import type { ArtisanProduct } from "@/data/artisans";

type Variant = "default" | "gallery" | "detailed";
interface Props { product: ArtisanProduct; variant?: Variant; loading?: boolean; }
const { product, variant = "default", loading = false } = Astro.props;

const palette: Record<string, [string, string]> = {
  bougie: ["#E2B594", "#9A4F2A"],
  marquepage: ["#C9A37D", "#7C4F31"],
  mug: ["#F2E7C4", "#C77A4F"],
  foulard: ["#C9B0C5", "#8E6C90"],
  savon: ["#C7CDB7", "#5A6647"],
  miel: ["#EAD9A6", "#C77A4F"],
  confiture: ["#C77A4F", "#5C3820"],
};
const [c1, c2] = palette[product.imageKey] ?? ["#C9A37D", "#7C4F31"];

let stockChip: { label: string; cls: string };
if (product.stock <= 0) stockChip = { label: "Sur commande", cls: "border-cocoa-200 text-cocoa-600 bg-cream-100" };
else if (product.stock <= 2) stockChip = { label: "Pièce unique", cls: "border-plum-400 text-plum-600 bg-cream-50" };
else stockChip = { label: "En stock", cls: "border-sage-400 text-sage-600 bg-cream-50" };
---
{loading ? (
  <div class="block animate-pulse" aria-busy="true">
    <div class="aspect-square rounded-2xl bg-gradient-to-br from-cream-100 to-cream-200/70" />
    <div class="mt-3 space-y-2">
      <div class="h-4 w-2/3 bg-cream-200 rounded" />
      <div class="h-3 w-1/2 bg-cream-100 rounded" />
      <div class="h-3 w-16 bg-cream-200 rounded" />
    </div>
  </div>
) : (
  <a href={`/artisans/${product.slug}`} class="group block">
    <div
      class="relative aspect-square rounded-2xl overflow-hidden border border-line transition-transform duration-300 ease-out group-hover:-translate-y-1"
      style={`background: linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`}
    >
      {/* Paper texture overlay */}
      <div class="paper-noise absolute inset-0 mix-blend-multiply opacity-[.06] pointer-events-none"></div>

      {/* Decorative circles top-right */}
      <svg
        class="absolute top-4 right-4 opacity-30 pointer-events-none"
        viewBox="0 0 60 60"
        width="50"
        height="50"
        fill="none"
        stroke="#FBF6E9"
        stroke-width="0.6"
        aria-hidden="true"
      >
        <circle cx="30" cy="30" r="22" />
        <circle cx="30" cy="30" r="14" />
        <circle cx="30" cy="30" r="3" fill="#FBF6E9" opacity=".5" />
      </svg>

      {/* Bottom name overlay (front only, no flip) */}
      {variant !== "gallery" && (
        <div class="absolute inset-x-0 bottom-0 p-5 bg-gradient-to-t from-black/30 to-transparent pointer-events-none">
          <p class="font-smallcap tracking-widest text-[10px] uppercase text-cream-50/85">{product.city}</p>
          <p class="font-display italic text-xl text-cream-50 mt-1 leading-tight" style="text-shadow: 0 1px 8px rgba(0,0,0,.25);">{product.name}</p>
        </div>
      )}
    </div>

    {variant !== "gallery" && (
      <div class="mt-3 px-1 flex items-start justify-between gap-3">
        <div class="min-w-0">
          <p class="font-display italic text-cocoa-600 text-base group-hover:text-terracotta-400 transition-colors truncate">
            {product.name}
          </p>
          <p class="font-body text-cocoa-400 text-xs mt-0.5 truncate">
            {product.artisan}, {product.city}
          </p>
          <p class="price-tab text-sm mt-1">{formatPrice(product.price)}</p>
        </div>
        <span class={`chip shrink-0 ${stockChip.cls}`}>{stockChip.label}</span>
      </div>
    )}

    {variant === "gallery" && (
      <div class="mt-2 px-1 flex items-center justify-between">
        <p class="price-tab text-sm">{formatPrice(product.price)}</p>
        <span class={`chip ${stockChip.cls}`}>{stockChip.label}</span>
      </div>
    )}
  </a>
)}
