---
import { formatPrice } from "@/lib/format";
import type { ArtisanProduct } from "@/data/artisans";
interface Props { product: ArtisanProduct; }
const { product } = Astro.props;

const palette: Record<string, [string, string]> = {
  bougie: ["#E2B594", "#9A4F2A"],
  marquepage: ["#C9A37D", "#7C4F31"],
  mug: ["#F2E7C4", "#C77A4F"],
  foulard: ["#C9B0C5", "#8E6C90"],
  savon: ["#C7CDB7", "#5A6647"],
  miel: ["#EAD9A6", "#C77A4F"],
  confiture: ["#C77A4F", "#5C3820"],
};
const [c1, c2] = palette[product.imageKey] ?? ["#C9A37D", "#7C4F31"];
---
<a href={`/artisans/${product.slug}`} class="group block [perspective:1200px]">
  <div class="relative aspect-square rounded-2xl transition-transform duration-700 [transform-style:preserve-3d] group-hover:[transform:rotateY(180deg)]">
    <div class="absolute inset-0 rounded-2xl border border-line overflow-hidden [backface-visibility:hidden]"
         style={`background: linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`}>
      <div class="absolute inset-0 flex items-end p-5">
        <div class="text-cream-50">
          <p class="font-smallcap tracking-widest text-[10px] uppercase opacity-80">{product.artisan}, {product.city}</p>
          <p class="font-display italic text-xl mt-1">{product.name}</p>
        </div>
      </div>
      <svg class="absolute top-4 right-4 opacity-30" viewBox="0 0 60 60" width="50" height="50" fill="none" stroke="#FBF6E9" stroke-width="0.6">
        <circle cx="30" cy="30" r="22"/>
        <circle cx="30" cy="30" r="14"/>
        <circle cx="30" cy="30" r="3" fill="#FBF6E9" opacity=".5"/>
      </svg>
    </div>
    <div class="absolute inset-0 rounded-2xl border border-line bg-cream-50 p-6 [transform:rotateY(180deg)] [backface-visibility:hidden] flex flex-col justify-between">
      <div>
        <p class="eyebrow">{product.artisan}</p>
        <p class="font-display italic text-lg text-cocoa-600 mt-1 leading-tight">{product.name}</p>
        <p class="text-xs text-cocoa-400 mt-3 line-clamp-5">{product.description}</p>
      </div>
      <div class="flex items-center justify-between">
        <span class="price-tab text-base">{formatPrice(product.price)}</span>
        <span class="chip">Voir</span>
      </div>
    </div>
  </div>
  <div class="mt-3 px-1">
    <p class="font-display italic text-cocoa-600 text-base group-hover:text-terracotta-400 transition-colors">{product.name}</p>
    <p class="font-body text-cocoa-400 text-xs mt-0.5">{product.artisan}, {product.city}</p>
    <p class="price-tab text-sm mt-1">{formatPrice(product.price)}</p>
  </div>
</a>
