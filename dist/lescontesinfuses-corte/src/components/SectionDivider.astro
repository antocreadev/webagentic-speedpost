---
interface Props {
  ornament?: "diamond" | "leaf" | "dot";
  class?: string;
}
const { ornament = "diamond", class: className = "" } = Astro.props;
---
<div class={`section-divider ${className}`} aria-hidden="true">
  {ornament === "diamond" && (
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
      <path d="M7 1 L13 7 L7 13 L1 7 Z" stroke="currentColor" stroke-width="1" fill="rgba(201,163,125,.15)"/>
    </svg>
  )}
  {ornament === "leaf" && (
    <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
      <path d="M1 7 Q9 1 17 7 Q9 13 1 7 Z" stroke="currentColor" stroke-width="1" fill="rgba(201,163,125,.12)"/>
      <path d="M1 7 L17 7" stroke="currentColor" stroke-width=".5" opacity=".5"/>
    </svg>
  )}
  {ornament === "dot" && (
    <span class="inline-block w-1.5 h-1.5 rounded-full" style="background:#C9A37D"></span>
  )}
</div>
