---
interface Props {
  name?: string;
  id?: string;
  required?: boolean;
  checked?: boolean;
  value?: string;
  label?: string;
  class?: string;
}
const { name, id, required, checked, value, label, class: className = "" } = Astro.props;
---
<label class={`lci-radio inline-flex items-start gap-2.5 cursor-pointer select-none ${className}`}>
  <input
    type="radio"
    name={name}
    id={id}
    required={required}
    checked={checked}
    value={value}
    class="peer sr-only"
  />
  <span class="lci-rdot relative shrink-0 mt-0.5 inline-flex items-center justify-center w-[18px] h-[18px] rounded-full border border-cocoa-200 bg-cream-50 transition-colors duration-200 peer-checked:border-terracotta-400 peer-focus-visible:ring-2 peer-focus-visible:ring-terracotta-400/40">
    <span class="lci-rdot-inner block w-[10px] h-[10px] rounded-full bg-terracotta-400 scale-0 transition-transform duration-200"></span>
  </span>
  {label && <span class="font-body text-sm text-cocoa-700 leading-snug">{label}</span>}
  <slot />
</label>

<style>
  .peer:checked ~ .lci-rdot .lci-rdot-inner { transform: scale(1); }
</style>
