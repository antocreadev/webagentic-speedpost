---
interface Props { size?: number; class?: string; }
const { size = 60, class: className = "" } = Astro.props;
---
<svg viewBox="0 0 60 100" width={size * 0.6} height={size} class={className} aria-hidden="true">
  <g stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round" stroke-linejoin="round">
    {/* flame */}
    <path d="M30 6 q -6 8, -4 16 q 2 6, 4 8 q 2 -2, 4 -8 q 2 -8, -4 -16 Z"/>
    <path d="M30 14 q -2 4, 0 10" opacity="0.6"/>
    {/* wick */}
    <path d="M30 30 L 30 36" stroke-width="1.4"/>
    {/* candle body */}
    <path d="M22 36 L 20 80 q 0 4, 4 4 L 36 84 q 4 0, 4 -4 L 38 36 Z"/>
    <path d="M22 36 L 38 36"/>
    {/* drips */}
    <path d="M22 50 q -2 6, 2 10 q 2 -2, 2 -6"/>
    <path d="M38 58 q 3 6, 0 12 q -3 -2, -3 -6"/>
    {/* holder base */}
    <path d="M16 84 L 14 92 L 46 92 L 44 84 Z"/>
    <path d="M14 92 L 46 92"/>
    <ellipse cx="30" cy="92" rx="16" ry="2"/>
  </g>
</svg>
