---
interface Props { size?: number; class?: string; }
const { size = 90, class: className = "" } = Astro.props;
---
<svg viewBox="0 0 120 120" width={size} height={size} class={className} aria-hidden="true">
  <defs>
    <path id="stamp-top" d="M 22,60 a 38,38 0 0 1 76,0"/>
    <path id="stamp-bottom" d="M 26,66 a 34,34 0 0 0 68,0"/>
  </defs>
  <g stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round">
    <circle cx="60" cy="60" r="54" stroke-dasharray="2 3" opacity="0.7"/>
    <circle cx="60" cy="60" r="46"/>
    <circle cx="60" cy="60" r="40" stroke-width="0.4" opacity="0.5"/>
    <text font-family="Cormorant SC, serif" font-size="9" fill="currentColor" stroke="none" letter-spacing="2">
      <textPath href="#stamp-top" startOffset="50%" text-anchor="middle">LES CONTES INFUSÉS</textPath>
    </text>
    <text font-family="Cormorant SC, serif" font-size="7" fill="currentColor" stroke="none" letter-spacing="3">
      <textPath href="#stamp-bottom" startOffset="50%" text-anchor="middle">CORTE · CORSICA</textPath>
    </text>
    {/* center cup */}
    <g transform="translate(60,62)">
      <path d="M -10 -2 L -8 8 q 0 3, 3 3 L 5 11 q 3 0, 3 -3 L 10 -2 Z"/>
      <path d="M 10 0 q 4 0, 4 4 q 0 4, -4 4"/>
      <path d="M -8 -6 q 0 -4, 0 -8" stroke-dasharray="1 2"/>
      <path d="M 0 -6 q 0 -4, 0 -8" stroke-dasharray="1 2"/>
      <path d="M 8 -6 q 0 -4, 0 -8" stroke-dasharray="1 2"/>
    </g>
    <circle cx="22" cy="60" r="1.4" fill="currentColor" stroke="none"/>
    <circle cx="98" cy="60" r="1.4" fill="currentColor" stroke="none"/>
  </g>
</svg>
