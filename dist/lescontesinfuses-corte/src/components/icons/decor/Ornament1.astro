---
interface Props { size?: number; class?: string; }
const { size = 80, class: className = "" } = Astro.props;
---
<svg viewBox="0 0 120 60" width={size} height={size * 0.5} class={className} aria-hidden="true">
  <g stroke="currentColor" stroke-width="0.7" fill="none" stroke-linecap="round">
    <path d="M5 30 L 45 30"/>
    <path d="M75 30 L 115 30"/>
    <g transform="translate(60,30)">
      <path d="M -14 0 q -6 -10, 0 -14 q 6 4, 0 14"/>
      <path d="M 14 0 q 6 -10, 0 -14 q -6 4, 0 14"/>
      <path d="M -14 0 q -6 10, 0 14 q 6 -4, 0 -14"/>
      <path d="M 14 0 q 6 10, 0 14 q -6 -4, 0 -14"/>
      <circle cx="0" cy="0" r="2.4"/>
      <circle cx="0" cy="0" r="0.8" fill="currentColor"/>
    </g>
    <circle cx="40" cy="30" r="1.4" fill="currentColor" stroke="none"/>
    <circle cx="80" cy="30" r="1.4" fill="currentColor" stroke="none"/>
    <path d="M50 30 q 4 -3, 0 -6"/>
    <path d="M70 30 q -4 -3, 0 -6"/>
    <path d="M50 30 q 4 3, 0 6"/>
    <path d="M70 30 q -4 3, 0 6"/>
  </g>
</svg>
