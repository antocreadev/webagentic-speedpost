---
interface Props { width?: number | string; height?: number; class?: string; }
const { width = "100%", height = 60, class: className = "" } = Astro.props;
---
<svg viewBox="0 0 400 60" width={width} height={height} class={className} preserveAspectRatio="none" aria-hidden="true">
  <g stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round">
    <path d="M0 0 Q 25 30, 50 8 Q 75 30, 100 8 Q 125 30, 150 8 Q 175 30, 200 8 Q 225 30, 250 8 Q 275 30, 300 8 Q 325 30, 350 8 Q 375 30, 400 0"/>
    <path d="M0 4 Q 25 34, 50 12 Q 75 34, 100 12 Q 125 34, 150 12 Q 175 34, 200 12 Q 225 34, 250 12 Q 275 34, 300 12 Q 325 34, 350 12 Q 375 34, 400 4" opacity="0.5"/>
    <g>
      <line x1="50" y1="30" x2="50" y2="44"/><circle cx="50" cy="48" r="3.5" fill="currentColor" stroke="none"/>
      <line x1="100" y1="30" x2="100" y2="50"/><circle cx="100" cy="54" r="4" fill="currentColor" stroke="none"/>
      <line x1="150" y1="30" x2="150" y2="44"/><circle cx="150" cy="48" r="3.5" fill="currentColor" stroke="none"/>
      <line x1="200" y1="30" x2="200" y2="52"/><circle cx="200" cy="56" r="4.5" fill="currentColor" stroke="none"/>
      <line x1="250" y1="30" x2="250" y2="44"/><circle cx="250" cy="48" r="3.5" fill="currentColor" stroke="none"/>
      <line x1="300" y1="30" x2="300" y2="50"/><circle cx="300" cy="54" r="4" fill="currentColor" stroke="none"/>
      <line x1="350" y1="30" x2="350" y2="44"/><circle cx="350" cy="48" r="3.5" fill="currentColor" stroke="none"/>
    </g>
  </g>
</svg>
