---
interface Props { size?: number; class?: string; }
const { size = 80, class: className = "" } = Astro.props;
---
<svg viewBox="0 0 100 60" width={size} height={size * 0.6} class={className} aria-hidden="true">
  <g stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round" stroke-linejoin="round">
    {/* left roll */}
    <ellipse cx="14" cy="30" rx="6" ry="14"/>
    <path d="M14 16 q -4 0, -4 4 m 4 -4 q 4 0, 4 4"/>
    <path d="M14 44 q -4 0, -4 -4 m 4 4 q 4 0, 4 -4"/>
    {/* parchment */}
    <path d="M14 16 L 86 16"/>
    <path d="M14 44 L 86 44"/>
    {/* lines of writing */}
    <path d="M22 24 L 78 24" stroke-dasharray="1 3" opacity="0.5"/>
    <path d="M22 30 L 72 30" stroke-dasharray="1 3" opacity="0.5"/>
    <path d="M22 36 L 78 36" stroke-dasharray="1 3" opacity="0.5"/>
    {/* right roll */}
    <ellipse cx="86" cy="30" rx="6" ry="14"/>
    <path d="M86 16 q -4 0, -4 4 m 4 -4 q 4 0, 4 4"/>
    <path d="M86 44 q -4 0, -4 -4 m 4 4 q 4 0, 4 -4"/>
  </g>
</svg>
