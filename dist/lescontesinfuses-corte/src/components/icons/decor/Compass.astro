---
interface Props { size?: number; class?: string; }
const { size = 80, class: className = "" } = Astro.props;
---
<svg viewBox="0 0 100 100" width={size} height={size} class={className} aria-hidden="true">
  <g stroke="currentColor" stroke-width="0.7" fill="none" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="50" r="44"/>
    <circle cx="50" cy="50" r="38" stroke-dasharray="1 3" opacity="0.6"/>
    <circle cx="50" cy="50" r="6"/>
    {/* cardinal points */}
    <path d="M50 6 L 54 46 L 50 50 L 46 46 Z" fill="currentColor" stroke="none" opacity="0.7"/>
    <path d="M50 94 L 54 54 L 50 50 L 46 54 Z"/>
    <path d="M6 50 L 46 54 L 50 50 L 46 46 Z"/>
    <path d="M94 50 L 54 54 L 50 50 L 54 46 Z"/>
    {/* diagonals */}
    <path d="M19 19 L 44 46"/>
    <path d="M81 19 L 56 46"/>
    <path d="M19 81 L 44 54"/>
    <path d="M81 81 L 56 54"/>
    {/* labels marks */}
    <circle cx="50" cy="10" r="1.4" fill="currentColor" stroke="none"/>
    <circle cx="50" cy="90" r="1.4" fill="currentColor" stroke="none"/>
    <circle cx="10" cy="50" r="1.4" fill="currentColor" stroke="none"/>
    <circle cx="90" cy="50" r="1.4" fill="currentColor" stroke="none"/>
    {/* tick marks */}
    {Array.from({ length: 24 }).map((_, i) => {
      const a = (i * 15 * Math.PI) / 180;
      const x1 = 50 + Math.cos(a) * 42;
      const y1 = 50 + Math.sin(a) * 42;
      const x2 = 50 + Math.cos(a) * 44;
      const y2 = 50 + Math.sin(a) * 44;
      return <line x1={x1} y1={y1} x2={x2} y2={y2} opacity="0.5"/>;
    })}
  </g>
</svg>
