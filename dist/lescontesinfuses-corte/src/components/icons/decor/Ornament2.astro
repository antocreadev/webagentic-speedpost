---
interface Props { size?: number; class?: string; }
const { size = 100, class: className = "" } = Astro.props;
---
<svg viewBox="0 0 160 40" width={size} height={size * 0.25} class={className} aria-hidden="true">
  <g stroke="currentColor" stroke-width="0.7" fill="none" stroke-linecap="round">
    <path d="M0 20 Q 20 12, 40 20"/>
    <path d="M120 20 Q 140 12, 160 20"/>
    <path d="M30 20 q 4 -2, 8 0"/>
    <path d="M22 20 q 3 -2, 6 0"/>
    <path d="M122 20 q 4 -2, 8 0"/>
    <path d="M132 20 q 3 -2, 6 0"/>
    <g transform="translate(80,20)">
      <path d="M -14 0 L 0 -10 L 14 0 L 0 10 Z"/>
      <path d="M -8 0 L 0 -5 L 8 0 L 0 5 Z"/>
      <circle cx="0" cy="0" r="1.4" fill="currentColor" stroke="none"/>
    </g>
    <circle cx="55" cy="20" r="1.2" fill="currentColor" stroke="none"/>
    <circle cx="105" cy="20" r="1.2" fill="currentColor" stroke="none"/>
  </g>
</svg>
