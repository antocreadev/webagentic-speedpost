---
interface Props { width?: number | string; height?: number; class?: string; repeat?: number; }
const { width = "100%", height = 24, class: className = "", repeat = 1 } = Astro.props;
const tile = (offset: number) => `
  <g transform="translate(${offset},0)" stroke="currentColor" stroke-width="0.7" fill="none" stroke-linecap="round">
    <path d="M0 12 L 200 12" stroke-width="0.4" opacity="0.7"/>
    <circle cx="10" cy="12" r="1.2" fill="currentColor" stroke="none"/>
    <path d="M28 6 L 30 12 L 28 18 L 26 12 Z" fill="currentColor" stroke="none" opacity="0.7"/>
    <circle cx="46" cy="12" r="1.2" fill="currentColor" stroke="none"/>
    <path d="M62 12 q 6 -8, 14 -6 q -2 6, -8 8 q -6 2, -6 -2 Z" fill="none"/>
    <path d="M68 8 q 4 -1, 8 0" />
    <circle cx="92" cy="12" r="1.2" fill="currentColor" stroke="none"/>
    <g transform="translate(108,12)">
      <path d="M -6 0 L 0 -5 L 6 0 L 0 5 Z"/>
      <circle cx="0" cy="0" r="1.2" fill="currentColor" stroke="none"/>
    </g>
    <circle cx="128" cy="12" r="1.2" fill="currentColor" stroke="none"/>
    <path d="M144 14 q 6 -10, 14 -6 q 2 4, -2 6 q -6 4, -12 0 Z" />
    <path d="M150 10 q 3 -1, 6 0" />
    <circle cx="174" cy="12" r="1.2" fill="currentColor" stroke="none"/>
    <path d="M188 6 L 190 12 L 188 18 L 186 12 Z" fill="currentColor" stroke="none" opacity="0.7"/>
  </g>
`;
const tiles = Array.from({ length: repeat }, (_, i) => tile(i * 200)).join("");
const totalW = 200 * repeat;
---
<svg
  viewBox={`0 0 ${totalW} 24`}
  width={width}
  height={height}
  class={className}
  preserveAspectRatio="xMidYMid meet"
  aria-hidden="true"
  set:html={tiles}
></svg>
