---
interface Props { size?: number; class?: string; }
const { size = 80, class: className = "" } = Astro.props;
---
<svg viewBox="0 0 80 80" width={size} height={size} class={className} aria-hidden="true">
  <g stroke="currentColor" stroke-width="0.8" fill="none" stroke-linecap="round">
    <rect x="6" y="6" width="68" height="68"/>
    <rect x="10" y="10" width="60" height="60" stroke-dasharray="1 2" opacity="0.6"/>
    <path d="M6 6 q -4 0, -4 4"/>
    <path d="M74 6 q 4 0, 4 4"/>
    <path d="M6 74 q -4 0, -4 -4"/>
    <path d="M74 74 q 4 0, 4 -4"/>
    <g>
      <circle cx="6" cy="6" r="1.6" fill="currentColor" stroke="none"/>
      <circle cx="74" cy="6" r="1.6" fill="currentColor" stroke="none"/>
      <circle cx="6" cy="74" r="1.6" fill="currentColor" stroke="none"/>
      <circle cx="74" cy="74" r="1.6" fill="currentColor" stroke="none"/>
    </g>
    <path d="M40 4 q -2 -3, -6 -3 m 6 3 q 2 -3, 6 -3"/>
    <path d="M40 76 q -2 3, -6 3 m 6 -3 q 2 3, 6 3"/>
    <path d="M4 40 q -3 -2, -3 -6 m 3 6 q -3 2, -3 6"/>
    <path d="M76 40 q 3 -2, 3 -6 m -3 6 q 3 2, 3 6"/>
  </g>
</svg>
