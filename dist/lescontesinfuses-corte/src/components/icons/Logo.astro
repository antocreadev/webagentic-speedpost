---
interface Props {
  size?: number;
  class?: string;
}
const { size = 80, class: className = "" } = Astro.props;
---
<svg
  viewBox="0 0 200 200"
  width={size}
  height={size}
  class={className}
  role="img"
  aria-label="Les Contes Infusés, librairie et café à Corte"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <path id="logo-circle-top" d="M 30,100 a 70,70 0 0 1 140,0" fill="none"/>
    <path id="logo-circle-bottom" d="M 40,108 a 60,60 0 0 0 120,0" fill="none"/>
  </defs>

  {/* outer thin frame */}
  <circle cx="100" cy="100" r="92" fill="none" stroke="#7C4F31" stroke-width="0.6"/>
  <circle cx="100" cy="100" r="78" fill="none" stroke="#7C4F31" stroke-width="0.4" stroke-dasharray="1 3"/>

  {/* curved title top */}
  <text font-family="Cormorant Garamond, serif" font-style="italic" font-size="14" fill="#4A2D1F" letter-spacing="2">
    <textPath href="#logo-circle-top" startOffset="50%" text-anchor="middle">Les Contes Infusés</textPath>
  </text>
  {/* curved subtitle bottom */}
  <text font-family="Cormorant SC, serif" font-size="7" fill="#7C4F31" letter-spacing="3">
    <textPath href="#logo-circle-bottom" startOffset="50%" text-anchor="middle">LIBRAIRIE  ·  CAFÉ</textPath>
  </text>

  {/* laurel left */}
  <g stroke="#7C4F31" stroke-width="0.8" fill="none" stroke-linecap="round">
    <path d="M30 110 Q 40 120, 50 132"/>
    <path d="M34 114 q 4 -2, 8 0"/>
    <path d="M38 120 q 4 -2, 8 0"/>
    <path d="M42 126 q 4 -2, 8 0"/>
  </g>
  {/* laurel right */}
  <g stroke="#7C4F31" stroke-width="0.8" fill="none" stroke-linecap="round">
    <path d="M170 110 Q 160 120, 150 132"/>
    <path d="M166 114 q -4 -2, -8 0"/>
    <path d="M162 120 q -4 -2, -8 0"/>
    <path d="M158 126 q -4 -2, -8 0"/>
  </g>

  {/* open book */}
  <g transform="translate(100,118)">
    <path d="M -36 0 Q -18 -8, 0 -2 Q 18 -8, 36 0 L 36 14 Q 18 6, 0 12 Q -18 6, -36 14 Z"
          fill="#FBF6E9" stroke="#4A2D1F" stroke-width="0.9"/>
    <path d="M 0 -2 L 0 12" stroke="#4A2D1F" stroke-width="0.6"/>
    <path d="M -28 2 q 12 -2, 24 1" stroke="#7C4F31" stroke-width="0.4" fill="none"/>
    <path d="M -28 5 q 12 -2, 24 1" stroke="#7C4F31" stroke-width="0.4" fill="none"/>
    <path d="M 4 1 q 12 -2, 24 1" stroke="#7C4F31" stroke-width="0.4" fill="none"/>
    <path d="M 4 4 q 12 -2, 24 1" stroke="#7C4F31" stroke-width="0.4" fill="none"/>
  </g>

  {/* teacup on book */}
  <g transform="translate(100,98)" stroke="#4A2D1F" fill="none" stroke-width="0.9" stroke-linecap="round">
    <path d="M -14 6 L -12 18 Q -12 22, -8 22 L 8 22 Q 12 22, 12 18 L 14 6 Z"/>
    <path d="M 14 9 q 6 0, 6 6 q 0 6, -6 6"/>
    <ellipse cx="0" cy="6" rx="14" ry="2.4" fill="#FBF6E9"/>
    {/* steam */}
    <path d="M -6 0 q -3 -4, 0 -8 q 3 -4, 0 -8" stroke-dasharray="1.5 2"/>
    <path d="M 0 0 q -3 -4, 0 -8 q 3 -4, 0 -8" stroke-dasharray="1.5 2"/>
    <path d="M 6 0 q -3 -4, 0 -8 q 3 -4, 0 -8" stroke-dasharray="1.5 2"/>
  </g>

  {/* small ornament dots */}
  <circle cx="100" cy="32" r="1.4" fill="#7C4F31"/>
  <circle cx="100" cy="172" r="1.4" fill="#7C4F31"/>
</svg>
