---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import UnifiedSearch from "@/components/islands/UnifiedSearch.tsx";
import { api, listBooks, listArtisans, getArtisanBySlug } from "@/lib/api";
import type { Event as ApiEvent } from "@/lib/api";
import { toItems, toLegacyBook, toLegacyEvent, toLegacyProduct, safe } from "@/lib/adapters";
import type { ArtisanProduct } from "@/data/artisans";

const initial = Astro.url.searchParams.get("q") ?? "";

const [booksRes, eventsRes, artisansRes] = await Promise.all([
  safe(listBooks({ limit: 100 }), [] as any),
  safe(api.get("catalog/events", { searchParams: { upcoming: false, limit: 100 } }).json<ApiEvent[]>(), [] as ApiEvent[]),
  safe(listArtisans(), []),
]);

const books = toItems(booksRes.data as any).map(toLegacyBook);
const events = (eventsRes.data ?? []).map(toLegacyEvent);

let artisans: ArtisanProduct[] = [];
const artisansList = artisansRes.data ?? [];
if (artisansList.length) {
  const details = await Promise.all(artisansList.map((a) => getArtisanBySlug(a.slug).catch(() => null)));
  for (const d of details) {
    if (!d) continue;
    for (const p of d.products ?? []) {
      artisans.push(toLegacyProduct(p, { name: d.name, city: d.city }));
    }
  }
}
---
<BaseLayout
  title="Recherche, Les Contes Infusés"
  description="Cherchez parmi les livres, les événements et les produits artisans."
>
  <section class="max-w-5xl mx-auto px-5 sm:px-8 pt-16 pb-10 text-center">
    <p class="eyebrow"><span class="filet"></span><span class="mx-3">Recherche unifiée</span><span class="filet"></span></p>
    <h1 class="font-display italic text-4xl md:text-6xl text-cocoa-600 mt-4 leading-[0.95]">
      Que voulez-vous trouver ?
    </h1>
    <p class="font-body italic text-cocoa-400 mt-4 text-sm max-w-md mx-auto">
      Un titre, un auteur, un événement, un produit. Tout, en une seule barre.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-24">
    <UnifiedSearch books={books} events={events} products={artisans} initialQuery={initial} client:load />
  </section>
</BaseLayout>
