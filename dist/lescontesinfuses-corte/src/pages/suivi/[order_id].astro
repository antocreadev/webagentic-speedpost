---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Check } from "lucide-react";
import { getOrderTracking, getOrder } from "@/lib/api";

const orderId = Astro.params.order_id as string;
const token = Astro.url.searchParams.get("token") ?? "";

let tracking: any = null;
let order: any = null;
let errorMsg: string | null = null;
if (!token) {
  errorMsg = "Lien de suivi invalide. Vérifiez l'email reçu après votre commande.";
} else {
  try {
    tracking = await getOrderTracking(orderId, token);
  } catch (e: any) {
    errorMsg = e?.message || "Suivi introuvable";
  }
  try { order = await getOrder(orderId, token); } catch { /* ignore */ }
}

const STATUS_STAGES: Record<string, number> = {
  paid: 1, confirmed: 1,
  preparing: 2, packed: 2,
  shipped: 3, in_transit: 3,
  delivered: 4, ready_pickup: 4,
};

const currentStatus = tracking?.status ?? order?.status ?? "paid";
const stage = STATUS_STAGES[currentStatus] ?? 1;
const events = tracking?.events ?? [];

const steps = [
  { n: 1, title: "Commande reçue", desc: "Paiement validé, préparation en cours." },
  { n: 2, title: "Colis préparé", desc: "Emballé à la main, place Paoli." },
  { n: 3, title: "En route", desc: "Pris en charge par le transporteur." },
  { n: 4, title: "Disponible", desc: "Prêt à être retiré ou remis." },
];

const trackingNumber = tracking?.tracking_number || order?.shipping?.tracking_number;
const shippingMethod = order?.shipping?.method;
---
<BaseLayout title={`Suivi commande ${orderId}, Les Contes Infusés`} description="Suivez l'acheminement de votre commande, de la préparation au point relais.">
  <section class="max-w-4xl mx-auto px-5 sm:px-8 py-12 md:py-16">
    {errorMsg ? (
      <div class="text-center py-16">
        <p class="eyebrow">Suivi indisponible</p>
        <h1 class="font-display italic text-4xl md:text-5xl text-cocoa-600 mt-3">Commande introuvable</h1>
        <p class="font-body text-cocoa-400 mt-3 max-w-lg mx-auto">{errorMsg}</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/retrouver-ma-commande" class="btn-terracotta">Retrouver ma commande</a>
          <a href="/contact" class="btn-ghost">Contacter la maison</a>
        </div>
      </div>
    ) : (
      <>
        <header class="mb-10">
          <p class="eyebrow">Suivi de commande</p>
          <h1 class="font-display italic text-4xl md:text-5xl text-cocoa-600 mt-2">Commande {orderId}</h1>
          <p class="font-body text-cocoa-400 mt-2">Voici l'avancée de votre paquet.</p>
        </header>

        {(trackingNumber || shippingMethod) && (
          <div class="bg-cream-50 border border-line rounded-2xl p-6 md:p-8 mb-8">
            <div class="flex flex-wrap items-center gap-4 justify-between">
              {trackingNumber && (
                <div>
                  <p class="font-smallcap tracking-widest uppercase text-[11px] text-cocoa-400">Numéro de suivi</p>
                  <p class="font-mono text-lg text-cocoa-700 tabular-nums mt-1">{trackingNumber}</p>
                  {shippingMethod === "relay" && (
                    <a href={`https://www.mondialrelay.fr/suivi-de-colis?numeroExpedition=${encodeURIComponent(trackingNumber)}`} target="_blank" rel="noopener" class="text-xs underline text-terracotta-400">Suivre sur Mondial Relay</a>
                  )}
                </div>
              )}
              {shippingMethod && (
                <div>
                  <p class="font-smallcap tracking-widest uppercase text-[11px] text-cocoa-400">Mode</p>
                  <p class="font-display italic text-lg text-cocoa-700 mt-1">
                    {shippingMethod === "relay" ? "Mondial Relay" : shippingMethod === "home" ? "Domicile" : "Click & Collect"}
                  </p>
                </div>
              )}
            </div>
          </div>
        )}

        <ol class="relative pl-8 sm:pl-10 space-y-8">
          <div class="absolute left-3 sm:left-4 top-2 bottom-2 w-px bg-line"></div>
          {steps.map((s) => {
            const isDone = stage >= s.n;
            const isCurrent = s.n === stage;
            const ev = events.find((e: any) => STATUS_STAGES[e.status] === s.n);
            return (
              <li class="relative">
                <div class={`absolute -left-8 sm:-left-10 top-0 w-7 h-7 rounded-full border-2 flex items-center justify-center ${isDone ? 'bg-terracotta-400 border-terracotta-400 text-cream-50' : 'bg-paper border-line text-cocoa-400'}`}>
                  {isDone ? <Check size={14} /> : <span class="text-xs tabular-nums">{s.n}</span>}
                </div>
                <div class={`bg-cream-50 border rounded-xl p-5 ${isCurrent ? 'border-terracotta-400 shadow-book' : 'border-line'}`}>
                  <div class="flex items-baseline justify-between gap-3 flex-wrap">
                    <p class="font-display italic text-xl text-cocoa-700">{s.title}</p>
                    {ev?.at && <p class="text-xs text-cocoa-400 tabular-nums font-sans">{new Date(ev.at).toLocaleString("fr-FR")}</p>}
                  </div>
                  <p class="text-sm text-cocoa-400 mt-1">{ev?.note ?? s.desc}</p>
                </div>
              </li>
            );
          })}
        </ol>

        <div class="mt-12 grid sm:grid-cols-2 gap-4">
          <a href="/contact" class="btn-ghost justify-center">Une question, écrire à la maison</a>
          <a href="/retrouver-ma-commande" class="btn-ghost justify-center">Toutes mes commandes</a>
        </div>
      </>
    )}
  </section>
</BaseLayout>
