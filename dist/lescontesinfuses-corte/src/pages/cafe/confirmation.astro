---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCafeOrder } from "@/lib/api";
import { formatPrice } from "@/lib/format";

const orderId = Astro.url.searchParams.get("order") ?? "";
const token = Astro.url.searchParams.get("token") ?? "";

let order: any = null;
let errorMsg: string | null = null;
if (orderId && token) {
  try { order = await getCafeOrder(orderId, token); } catch (e: any) { errorMsg = e?.message || "Commande introuvable"; }
} else { errorMsg = "Paramètres manquants"; }

const items = order?.items ?? [];
const totalCents = order?.total_cents ?? 0;
---
<BaseLayout title="Click & collect confirmé, Les Contes Infusés" description="Votre commande au café est prise.">
  <section class="max-w-2xl mx-auto px-5 sm:px-8 py-16">
    {errorMsg ? (
      <div class="text-center">
        <p class="eyebrow">Oups</p>
        <h1 class="font-display italic text-4xl text-cocoa-600 mt-3">Commande introuvable</h1>
        <p class="text-cocoa-400 mt-3">{errorMsg}</p>
        <a href="/cafe/commander" class="btn-terracotta mt-6 inline-flex">Reprendre une commande</a>
      </div>
    ) : (
      <>
        <p class="eyebrow text-center">Click & collect</p>
        <h1 class="font-display italic text-4xl md:text-5xl text-cocoa-600 mt-3 text-center">Votre commande est prise</h1>
        <p class="text-cocoa-400 text-center mt-3">Numéro <span class="tabular-nums font-display italic text-cocoa-700">{orderId}</span></p>
        {items.length > 0 && (
          <div class="bg-cream-50 border border-line rounded-2xl p-6 mt-8">
            <ul class="divide-y divide-line">
              {items.map((it: any) => (
                <li class="py-3 flex justify-between text-sm">
                  <span>{it.title ?? it.boisson_slug ?? it.slug} <span class="text-cocoa-400">×{it.qty ?? it.quantity}</span></span>
                  <span class="price-tab">{formatPrice(((it.unit_price_cents ?? 0) * (it.qty ?? it.quantity ?? 1)) / 100)}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 pt-4 border-t border-line flex justify-between items-baseline">
              <span class="font-smallcap uppercase tracking-widest text-sm">Total</span>
              <span class="font-display italic text-2xl text-terracotta-400">{formatPrice(totalCents / 100)}</span>
            </div>
          </div>
        )}
        <p class="text-center text-cocoa-400 mt-6 text-sm">Présentez ce numéro au comptoir, place Paoli. Paiement sur place.</p>
        <div class="text-center mt-8">
          <a href="/cafe" class="btn-ghost">Retour à la carte</a>
        </div>
      </>
    )}
  </section>
</BaseLayout>
