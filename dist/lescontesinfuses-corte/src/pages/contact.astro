---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/islands/ContactForm.tsx";
import Quill from "@/components/icons/Quill.astro";
---
<BaseLayout
  title="Contact, Les Contes Infusés, Corte"
  description="Place Paoli, 20250 Corte. Mardi à samedi, 10h à 19h. Email contact@lescontesinfuses.corsica."
>
  <section class="max-w-6xl mx-auto px-5 sm:px-8 pt-14 pb-12 text-center" data-chapter="1">
    <p class="eyebrow" data-reveal><span class="filet"></span><span class="mx-3">Écrire, passer, appeler</span><span class="filet"></span></p>
    <h1 class="font-display italic text-5xl md:text-7xl text-cocoa-600 mt-4 leading-[0.95]" data-reveal data-fade-direction="scale">
      Contactez la maison
    </h1>
    <p class="font-body italic text-cocoa-400 mt-4 max-w-xl mx-auto">
      Un mot, une question, une commande spéciale. On vous répond depuis Corte, sous 48h ouvrées.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-16 grid lg:grid-cols-[1.1fr_1fr] gap-10" data-chapter="2">
    <div>
      <ContactForm client:load />
    </div>
    <aside class="bg-cream-50 border border-line rounded-2xl p-8 md:p-10">
      <div class="flex items-start gap-3 mb-6">
        <Quill size={36} class="opacity-70" />
        <div>
          <p class="eyebrow">Adresse</p>
          <p class="font-display italic text-2xl text-cocoa-600 mt-1">Place Paoli, 20250 Corte</p>
        </div>
      </div>
      <dl class="grid sm:grid-cols-2 gap-6 font-body text-cocoa-700 text-sm">
        <div>
          <dt class="eyebrow">Email</dt>
          <dd class="mt-1"><a href="mailto:contact@lescontesinfuses.corsica" class="hover:text-terracotta-400">contact@lescontesinfuses.corsica</a></dd>
        </div>
        <div>
          <dt class="eyebrow">Téléphone</dt>
          <dd class="mt-1"><a href="tel:+33495610000" class="hover:text-terracotta-400">04 95 61 00 00</a></dd>
        </div>
        <div class="sm:col-span-2 pt-2 border-t border-line">
          <dt class="eyebrow">Horaires</dt>
          <dd class="mt-1">
            Mardi à samedi.<br/>
            10h, 13h et 14h, 19h.
            <span class="block mt-1 italic text-cocoa-400">Fermé dimanche et lundi.</span>
          </dd>
        </div>
        <div class="sm:col-span-2 pt-2 border-t border-line">
          <dt class="eyebrow">Réseaux</dt>
          <dd class="mt-2 flex gap-2">
            <a href="/social" class="chip hover:border-terracotta-400">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="20" x="2" y="2" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".8" fill="currentColor"/></svg>
              Instagram
            </a>
            <a href="/social" class="chip hover:border-terracotta-400">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </a>
          </dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-20">
    <div class="rounded-2xl overflow-hidden border border-line shadow-page aspect-[16/9]">
      <iframe
        title="Carte Place Paoli, Corte"
        src="https://maps.google.com/maps?q=42.305,9.149&z=15&output=embed"
        class="w-full h-full border-0"
        loading="lazy"
      ></iframe>
    </div>
    <div class="mt-10 grid md:grid-cols-3 gap-6" data-stagger="100">
      <div class="bg-cream-50 border border-line rounded-2xl p-6">
        <p class="eyebrow">À pied</p>
        <p class="font-body text-sm text-cocoa-700 mt-2">Cinq minutes depuis la citadelle, en descendant la rue Scoliscia.</p>
      </div>
      <div class="bg-cream-50 border border-line rounded-2xl p-6">
        <p class="eyebrow">En voiture</p>
        <p class="font-body text-sm text-cocoa-700 mt-2">Parking gratuit Place du Palais, à 200 mètres. Trois places PMR sur la place.</p>
      </div>
      <div class="bg-cream-50 border border-line rounded-2xl p-6">
        <p class="eyebrow">En train</p>
        <p class="font-body text-sm text-cocoa-700 mt-2">Gare de Corte, ligne Bastia, Ajaccio. Huit minutes à pied jusqu'à la place.</p>
      </div>
    </div>
  </section>
</BaseLayout>
