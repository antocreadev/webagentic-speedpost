---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import LaurelBranch from "@/components/icons/LaurelBranch.astro";
import LaceMedallion from "@/components/icons/LaceMedallion.astro";
import Teapot from "@/components/icons/Teapot.astro";
import CoffeeBean from "@/components/icons/CoffeeBean.astro";
import Quill from "@/components/icons/Quill.astro";
import Newsletter from "@/components/Newsletter.astro";
import EventCard from "@/components/cards/EventCard.astro";
import ProductCard from "@/components/cards/ProductCard.astro";
import BoissonCard from "@/components/cards/BoissonCard.astro";
import BookCard from "@/components/cards/BookCard.tsx";
import SectionDivider from "@/components/SectionDivider.astro";
import Frise from "@/components/icons/decor/Frise.astro";
import { api, listBooks, listCafe, listArtisans, getArtisanBySlug } from "@/lib/api";
import type { Event as ApiEvent } from "@/lib/api";
import { toItems, toLegacyBook, toLegacyEvent, toLegacyBoisson, toLegacyProduct, safe } from "@/lib/adapters";
import type { ArtisanProduct } from "@/data/artisans";

const [booksRes, eventsRes, cafeRes, artisansRes] = await Promise.all([
  safe(listBooks({ limit: 100 }), [] as any),
  safe(api.get("catalog/events", { searchParams: { upcoming: true, limit: 6 } }).json<ApiEvent[]>(), [] as ApiEvent[]),
  safe(listCafe(), []),
  safe(listArtisans(), []),
]);

const allBooks = toItems(booksRes.data as any).map(toLegacyBook);
const featuredBooks = allBooks.filter((b) => b.coupDeCoeur).slice(0, 4);
// Fallback: if no coup_de_coeur returned, take 4 first.
if (featuredBooks.length === 0) featuredBooks.push(...allBooks.slice(0, 4));

const featuredEvents = (eventsRes.data ?? []).map(toLegacyEvent).slice(0, 3);

const allBoissons = (cafeRes.data ?? []).map(toLegacyBoisson);
const featuredBoissons = [
  ...allBoissons.filter((c) => c.signature),
  ...allBoissons.filter((c) => !c.signature),
].slice(0, 6);

let featuredArtisans: ArtisanProduct[] = [];
const artisansList = artisansRes.data ?? [];
if (artisansList.length) {
  // Take products from first few artisans to avoid too many calls.
  const first = artisansList.slice(0, 4);
  const details = await Promise.all(first.map((a) => getArtisanBySlug(a.slug).catch(() => null)));
  for (const d of details) {
    if (!d) continue;
    for (const p of d.products ?? []) {
      featuredArtisans.push(toLegacyProduct(p, { name: d.name, city: d.city }));
      if (featuredArtisans.length >= 4) break;
    }
    if (featuredArtisans.length >= 4) break;
  }
}

const insta = [
  ["#5C3820", "#3A2014"], ["#C77A4F", "#9A4F2A"], ["#8A9876", "#5A6647"],
  ["#8E6C90", "#5E456A"], ["#E2B594", "#C77A4F"], ["#C9A37D", "#7C4F31"],
];
---
<BaseLayout
  title="Les Contes Infusés, librairie et café à Corte"
  description="Une librairie indépendante au pied de la citadelle de Corte. Un café qui sent le grain et le papier. Lire, infuser, recommencer."
>
  {/* HERO */}
  <section class="relative overflow-hidden" data-chapter="1">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-20 -left-32 w-[520px] opacity-60" data-parallax="0.35">
        <LaurelBranch size={520} />
      </div>
      <div class="absolute top-40 -right-32 w-[520px] opacity-60" data-parallax="0.5">
        <LaurelBranch size={520} flip />
      </div>
    </div>
    <div class="relative max-w-5xl mx-auto px-5 sm:px-8 pt-12 md:pt-20 pb-24 text-center">
      <div class="inline-flex items-center gap-2 chip border-terracotta-400 text-terracotta-600 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-terracotta-400 animate-pulse"></span>
        Ouverture prochaine, Place Paoli, Corte
      </div>

      <p class="eyebrow">
        <span class="filet"></span>
        <span class="mx-3">Librairie & Café · Corte</span>
        <span class="filet"></span>
      </p>

      <h1 class="font-display italic text-5xl sm:text-7xl md:text-[8rem] text-cocoa-600 mt-6 leading-[0.95] tracking-tight" data-reveal data-fade-direction="scale">
        Les Contes <span class="block sm:inline">Infusés</span>
      </h1>

      <p class="font-script text-3xl md:text-4xl text-terracotta-400 mt-6" data-reveal data-fade-direction="up" style="transition-delay:200ms">Lire, infuser, recommencer.</p>
      <p class="font-body italic text-cocoa-400 max-w-xl mx-auto mt-4 text-base md:text-lg">
        Une librairie indépendante au pied de la citadelle. Un café qui sent le grain et le papier. Des livres qu'on choisit avec lenteur.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/livres" class="btn-terracotta">Découvrir le catalogue</a>
        <a href="/cafe" class="btn-ghost">Voir la carte café</a>
      </div>

      <div class="mt-16 flex justify-center opacity-70" data-parallax="0.25">
        <Teapot size={70} />
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* MANIFESTO */}
  <section class="max-w-3xl mx-auto px-5 sm:px-8 py-20 text-center" data-chapter="2">
    <div class="flex justify-center mb-6">
      <span class="filet w-32"></span>
    </div>
    <p class="font-display italic text-2xl md:text-3xl text-cocoa-600 leading-relaxed" data-reveal data-fade-direction="up">
      Une librairie indépendante au pied de la citadelle de Corte. Un café qui sent le grain et le papier. Des livres qu'on choisit avec lenteur, parce qu'ici on prend le temps.
    </p>
    <p class="font-body text-cocoa-400 mt-6 text-base md:text-lg italic">
      On infuse les mots comme un thé long. On revient le mardi pour la nouveauté de l'éditeur, le samedi pour la lecture à voix basse, n'importe quel jour pour la conversation. C'est tout, c'est déjà beaucoup.
    </p>
    <div class="flex justify-center mt-8">
      <span class="filet w-32"></span>
    </div>
  </section>

  {/* COUPS DE CŒUR */}
  <section class="bg-cream-100/40 border-y border-line py-20" data-chapter="3">
    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <header class="text-center mb-14">
        <p class="eyebrow" data-reveal data-fade-direction="up">Sélection du mois</p>
        <h2 class="font-display italic text-4xl md:text-6xl text-cocoa-600 mt-3" data-reveal data-fade-direction="left">Coups de cœur</h2>
        <p class="font-body text-cocoa-400 max-w-xl mx-auto mt-4" data-reveal data-fade-direction="up" style="transition-delay:120ms">Quatre titres choisis avec passion par l'équipe, lus et commentés en boutique.</p>
      </header>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10" data-stagger="100">
        {featuredBooks.map((b) => <BookCard book={b} client:visible />)}
      </div>
      <div class="text-center mt-14">
        <a href="/livres" class="btn-ghost">Tout le catalogue</a>
      </div>
    </div>
  </section>

  <SectionDivider ornament="leaf" />

  {/* CARTE CAFÉ */}
  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-20" data-chapter="4">
    <header class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <p class="eyebrow" data-reveal data-fade-direction="up">À l'instant</p>
        <h2 class="font-display italic text-4xl md:text-6xl text-cocoa-600 mt-2" data-reveal data-fade-direction="left">La carte café</h2>
        <p class="font-body text-cocoa-400 max-w-xl mt-3" data-reveal data-fade-direction="up" style="transition-delay:120ms">Pure origine, lait vapeur, infusions du jardin et thé glacé maison. Préparé sous vos yeux.</p>
      </div>
      <a href="/cafe" class="btn-ghost shrink-0" data-reveal data-fade-direction="right">Carte complète</a>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" data-stagger="80">
      {featuredBoissons.map((b) => <BoissonCard item={b} />)}
    </div>
  </section>

  {/* ÉVÉNEMENTS */}
  <section class="bg-cocoa-800 text-cream-100 py-20" data-chapter="5">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <header class="text-center mb-12">
        <p class="font-smallcap tracking-windier text-xs text-terracotta-200 uppercase" data-reveal>Calendrier</p>
        <h2 class="font-display italic text-4xl md:text-6xl text-cream-50 mt-3" data-reveal data-fade-direction="left">Événements à venir</h2>
        <p class="font-body text-cream-100/70 max-w-xl mx-auto mt-4" data-reveal data-fade-direction="up" style="transition-delay:120ms">Dédicaces, club lecture, contes du soir : la maison vit en plusieurs voix.</p>
      </header>
      <div class="space-y-4 [&_article]:bg-cream-50/95 [&_article]:border-cream-50/30" data-stagger="120">
        {featuredEvents.map((e) => <EventCard event={e} />)}
      </div>
      <div class="text-center mt-12">
        <a href="/evenements" class="inline-flex items-center gap-2 text-cream-50 font-smallcap tracking-widest uppercase text-xs hover:text-terracotta-200 transition">
          Voir le calendrier complet
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <SectionDivider />

  {/* ARTISANS */}
  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-20" data-chapter="6">
    <header class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <p class="eyebrow" data-reveal>Artisanat corse</p>
        <h2 class="font-display italic text-4xl md:text-6xl text-cocoa-600 mt-2" data-reveal data-fade-direction="left">Faits, ici, à la main</h2>
        <p class="font-body text-cocoa-400 max-w-xl mt-3" data-reveal data-fade-direction="up" style="transition-delay:120ms">Bougies, papeterie, céramique, textile, douceurs : huit pièces choisies, toutes corses.</p>
      </div>
      <a href="/artisans" class="btn-ghost shrink-0" data-reveal data-fade-direction="right">Tout l'artisanat</a>
    </header>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6" data-stagger="90">
      {featuredArtisans.map((p) => <ProductCard product={p} />)}
    </div>
  </section>

  <SectionDivider ornament="leaf" />

  {/* CITATION SCRIPT */}
  <section class="relative py-28 overflow-hidden" data-chapter="7">
    <div class="absolute inset-0 pointer-events-none flex items-center justify-center opacity-30" data-parallax="0.2">
      <LaceMedallion size={560} />
    </div>
    <blockquote class="relative max-w-4xl mx-auto px-5 sm:px-8 text-center" data-quote-zoom>
      <p class="font-script text-5xl md:text-7xl text-terracotta-400 leading-[1.05]">
        Le café est un livre, le livre est une infusion.
      </p>
      <footer class="mt-8 eyebrow">
        <span class="filet"></span>
        <span class="mx-3">La maison</span>
        <span class="filet"></span>
      </footer>
    </blockquote>
  </section>

  {/* SOCIAL + NEWSLETTER */}
  <section class="bg-cream-100/40 border-y border-line py-20" data-chapter="8">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 grid lg:grid-cols-2 gap-16">
      <div>
        <p class="eyebrow">Sur Instagram</p>
        <h2 class="font-display italic text-3xl md:text-5xl text-cocoa-600 mt-2">@lescontesinfuses</h2>
        <p class="font-body text-cocoa-400 mt-3">Les rayons à l'aube, la machine qui fume, les visages des auteurs invités.</p>
        <div class="mt-6 grid grid-cols-3 gap-2">
          {insta.map(([c1, c2], i) => (
            <a href="#" aria-label={`Photo Instagram ${i+1}`} class="aspect-square rounded-md transition-transform hover:scale-[1.02]"
               style={`background: linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`}>
              <div class="w-full h-full rounded-md flex items-center justify-center">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#FBF6E9" stroke-width="1.5" opacity=".5">
                  <rect width="20" height="20" x="2" y="2" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".8" fill="#FBF6E9"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
      <div class="flex items-center">
        <Newsletter class="w-full" />
      </div>
    </div>
  </section>

  {/* VISITE + HORAIRES */}
  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-20">
    <header class="text-center mb-12">
      <p class="eyebrow">Vous nous trouverez</p>
      <h2 class="font-display italic text-4xl md:text-6xl text-cocoa-600 mt-3">Place Paoli, Corte</h2>
    </header>
    <div class="grid lg:grid-cols-2 gap-10 items-stretch">
      <div class="rounded-2xl overflow-hidden border border-line shadow-page min-h-[360px]">
        <iframe
          title="Carte de Corte, Place Paoli"
          src="https://maps.google.com/maps?q=42.3068,9.1500&z=15&output=embed"
          class="w-full h-full border-0"
          loading="lazy"
        ></iframe>
      </div>
      <div class="bg-cream-50 border border-line rounded-2xl p-8 md:p-10">
        <div class="flex items-start gap-3">
          <Quill size={36} class="opacity-70" />
          <div>
            <p class="eyebrow">Adresse</p>
            <p class="font-display italic text-2xl text-cocoa-600 mt-1">Place Paoli, 20250 Corte</p>
          </div>
        </div>
        <div class="mt-8 grid sm:grid-cols-2 gap-6 font-body text-cocoa-700">
          <div>
            <p class="eyebrow">Horaires</p>
            <p class="mt-2">Mardi à samedi</p>
            <p>10h, 13h</p>
            <p>14h, 19h</p>
            <p class="mt-2 text-cocoa-400 text-sm italic">Fermé dimanche et lundi</p>
          </div>
          <div>
            <p class="eyebrow">Contact</p>
            <p class="mt-2"><a href="mailto:contact@lescontesinfuses.corsica" class="hover:text-terracotta-400">contact@lescontesinfuses.corsica</a></p>
            <p><a href="tel:+33495610000" class="hover:text-terracotta-400">04 95 61 00 00</a></p>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-line flex items-center gap-6 opacity-80">
          <CoffeeBean size={28} />
          <Teapot size={48} />
          <Quill size={36} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
