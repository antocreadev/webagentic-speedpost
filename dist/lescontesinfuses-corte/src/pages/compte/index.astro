---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { books } from "@/data/books";
import BookCard from "@/components/cards/BookCard.tsx";

const cards = [
  { href: "/compte/commandes", eyebrow: "Historique", title: "Mes commandes", desc: "Cinq commandes passées, deux en cours d'acheminement.", icon: "shopping-bag" },
  { href: "/compte/informations", eyebrow: "Profil", title: "Mes informations", desc: "Adresse, téléphone, email. À jour.", icon: "user" },
  { href: "/compte/preferences", eyebrow: "Préférences", title: "Newsletter et alertes", desc: "Lettre mensuelle, rappels d'événements.", icon: "mail" },
  { href: "/compte/donnees", eyebrow: "RGPD", title: "Mes données", desc: "Export, suppression, journal de consentement.", icon: "shield" },
];
const icons: Record<string, string> = {
  "shopping-bag": '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>',
  user: '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
};
const favs = books.filter(b => b.coupDeCoeur).slice(0, 4);
---
<BaseLayout title="Mon compte, Les Contes Infusés" description="Espace personnel : commandes, préférences, données.">
  <section class="max-w-6xl mx-auto px-5 sm:px-8 py-12 md:py-16">
    <header class="mb-10">
      <p class="eyebrow">Espace personnel</p>
      <h1 class="font-display italic text-5xl md:text-6xl text-cocoa-600 mt-2">Bonjour Jean</h1>
      <p class="font-body italic text-cocoa-400 mt-3 max-w-xl">Ravis de vous retrouver. Voici un raccourci vers vos commandes, vos préférences et vos données.</p>
    </header>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-16">
      {cards.map(c => (
        <a href={c.href} class="group bg-cream-50 border border-line rounded-2xl p-6 hover:border-terracotta-400 hover:shadow-book transition-all">
          <div class="w-10 h-10 rounded-full bg-terracotta-50 flex items-center justify-center mb-4">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C77A4F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[c.icon]} />
          </div>
          <p class="font-smallcap tracking-widest uppercase text-[10px] text-cocoa-400">{c.eyebrow}</p>
          <p class="font-display italic text-xl text-cocoa-700 mt-1 group-hover:text-terracotta-400 transition-colors">{c.title}</p>
          <p class="text-xs text-cocoa-400 mt-2 leading-relaxed">{c.desc}</p>
        </a>
      ))}
    </div>

    <div class="border-t border-line pt-12">
      <header class="flex items-end justify-between mb-8 flex-wrap gap-3">
        <div>
          <p class="eyebrow">Pour vous</p>
          <h2 class="font-display italic text-3xl md:text-4xl text-cocoa-600 mt-1">Vos coups de cœur sauvegardés</h2>
        </div>
        <a href="/livres" class="btn-ghost">Continuer à explorer</a>
      </header>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {favs.map(b => <BookCard book={b} client:visible />)}
      </div>
    </div>
  </section>
</BaseLayout>
