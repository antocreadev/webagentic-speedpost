---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import MyAccount from "@/components/islands/MyAccount.tsx";
---
<BaseLayout title="Mon compte, Les Contes Infusés" description="Espace personnel : commandes, préférences, données.">
  <AuthGuard redirectTo="/auth/connexion?next=/compte" requireAdmin={false} />
  <section class="max-w-6xl mx-auto px-5 sm:px-8 py-12 md:py-16">
    <MyAccount client:load />
  </section>
</BaseLayout>
