---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import { MyPreferencesForm } from "@/components/islands/MyAccount.tsx";
---
<BaseLayout title="Préférences, Les Contes Infusés">
  <AuthGuard redirectTo="/auth/connexion?next=/compte/preferences" requireAdmin={false} />
  <section class="max-w-3xl mx-auto px-5 sm:px-8 py-12 md:py-16">
    <header class="mb-10">
      <p class="eyebrow"><a href="/compte" class="hover:text-terracotta-400">Compte</a> · Préférences</p>
      <h1 class="font-display italic text-4xl md:text-5xl text-cocoa-600 mt-2">Préférences</h1>
      <p class="font-body text-cocoa-400 mt-2">Maîtrisez ce que la maison vous adresse, et quand.</p>
    </header>
    <MyPreferencesForm client:load />
  </section>
</BaseLayout>
