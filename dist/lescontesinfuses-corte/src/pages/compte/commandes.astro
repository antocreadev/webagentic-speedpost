---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatPrice } from "@/lib/format";
import EmptyOrders from "@/components/empty/EmptyOrders.astro";

const isEmpty = Astro.url.searchParams.get("empty") === "1";

const orders = isEmpty ? [] : [
  { id: "CI-2026-0028", date: "12 avril 2026", total: 47.5, status: "Livrée", statusColor: "sage", items: ["Murtoriu", "Le Petit Prince", "Marque-page cuir Asco"], shipping: "Mondial Relay" },
  { id: "CI-2026-0021", date: "28 mars 2026", total: 22.0, status: "Livrée", statusColor: "sage", items: ["Persepolis intégrale"], shipping: "Click & Collect" },
  { id: "CI-2026-0017", date: "14 mars 2026", total: 64.0, status: "Livrée", statusColor: "sage", items: ["Corse secrète", "Atlas des sentiers"], shipping: "Domicile" },
  { id: "CI-2026-0009", date: "02 mars 2026", total: 31.5, status: "Livrée", statusColor: "sage", items: ["Mémoires d'Hadrien", "Bougie maquis"], shipping: "Mondial Relay" },
  { id: "CI-2026-0042", date: "19 avril 2026", total: 38.9, status: "En préparation", statusColor: "terracotta", items: ["Le sermon sur la chute de Rome", "Plein soleil"], shipping: "Mondial Relay" },
];
---
<BaseLayout title="Mes commandes, Les Contes Infusés" description="Historique de vos commandes, statuts et suivi.">
  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-12 md:py-16">
    <header class="mb-10">
      <p class="eyebrow"><a href="/compte" class="hover:text-terracotta-400">Compte</a> · Commandes</p>
      <h1 class="font-display italic text-4xl md:text-5xl text-cocoa-600 mt-2">Mes commandes</h1>
      <p class="font-body text-cocoa-400 mt-2">{isEmpty ? "Aucune commande pour l'instant." : "Cinq commandes passées depuis l'ouverture du compte."}</p>
    </header>

    {isEmpty ? (
      <EmptyOrders />
    ) : (
    <>
    <div class="flex flex-wrap gap-2 mb-6">
      <button class="chip border-cocoa-200 text-cocoa-700">Toutes (5)</button>
      <button class="chip">Livrées (4)</button>
      <button class="chip">En cours (1)</button>
      <button class="chip">Cette année</button>
    </div>

    <div class="bg-cream-50 border border-line rounded-2xl overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-cream-100/70 border-b border-line">
          <tr class="text-left">
            <th class="font-smallcap tracking-widest uppercase text-[10px] text-cocoa-400 px-5 py-3">N°</th>
            <th class="font-smallcap tracking-widest uppercase text-[10px] text-cocoa-400 px-5 py-3 hidden md:table-cell">Date</th>
            <th class="font-smallcap tracking-widest uppercase text-[10px] text-cocoa-400 px-5 py-3 hidden md:table-cell">Articles</th>
            <th class="font-smallcap tracking-widest uppercase text-[10px] text-cocoa-400 px-5 py-3">Statut</th>
            <th class="font-smallcap tracking-widest uppercase text-[10px] text-cocoa-400 px-5 py-3 text-right">Total</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line">
          {orders.map(o => (
            <tr class="hover:bg-cream-100/30 transition-colors">
              <td class="px-5 py-4 font-mono text-xs text-cocoa-700 tabular-nums">{o.id}</td>
              <td class="px-5 py-4 text-cocoa-400 hidden md:table-cell">{o.date}</td>
              <td class="px-5 py-4 text-cocoa-700 hidden md:table-cell max-w-[260px] truncate">{o.items.join(", ")}</td>
              <td class="px-5 py-4">
                <span class={`inline-flex items-center gap-1.5 text-xs px-2 py-1 rounded-full ${o.statusColor === 'sage' ? 'bg-sage-200/40 text-sage-600' : 'bg-terracotta-50 text-terracotta-600'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full ${o.statusColor === 'sage' ? 'bg-sage-400' : 'bg-terracotta-400'}`}></span>
                  {o.status}
                </span>
              </td>
              <td class="px-5 py-4 text-right price-tab tabular-nums">{formatPrice(o.total)}</td>
              <td class="px-5 py-4 text-right">
                <a href={`/suivi/${o.id}`} class="text-xs text-terracotta-400 hover:underline">Suivre</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    </>
    )}
  </section>
</BaseLayout>
