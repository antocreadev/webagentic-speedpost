---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import { MyOrdersList } from "@/components/islands/MyAccount.tsx";
---
<BaseLayout title="Mes commandes, Les Contes Infusés" description="Historique de vos commandes, statuts et suivi.">
  <AuthGuard redirectTo="/auth/connexion?next=/compte/commandes" requireAdmin={false} />
  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-12 md:py-16">
    <header class="mb-10">
      <p class="eyebrow"><a href="/compte" class="hover:text-terracotta-400">Compte</a> · Commandes</p>
      <h1 class="font-display italic text-4xl md:text-5xl text-cocoa-600 mt-2">Mes commandes</h1>
      <p class="font-body text-cocoa-400 mt-2">Historique et suivi de vos commandes.</p>
    </header>
    <MyOrdersList client:load />
  </section>
</BaseLayout>
