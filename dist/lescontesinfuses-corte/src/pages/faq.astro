---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FaqSearch from "@/components/islands/FaqSearch.tsx";
import { Mail } from "lucide-react";

const categories = [
  {
    name: "Visiter",
    slug: "visiter",
    items: [
      { q: "Où êtes-vous exactement ?", a: "Place Paoli à Corte (20250), au pied de la citadelle, deuxième vitrine en partant de la fontaine." },
      { q: "Quels sont les horaires ?", a: "Mardi à samedi, 10h à 13h et 14h à 19h. Fermé dimanche et lundi." },
      { q: "Y a-t-il un parking proche ?", a: "Oui, parking de la République à 200 mètres et parking Place du Duc à 400 mètres. Les deux sont gratuits le samedi." },
      { q: "Le lieu est-il accessible aux personnes à mobilité réduite ?", a: "Oui, entrée plain-pied, allées de 1m20 minimum, toilettes accessibles à l'arrière de la salle." },
      { q: "Acceptez-vous les chiens ?", a: "Les chiens calmes et tenus sont les bienvenus. Une gamelle d'eau les attend près de la porte." },
      { q: "Peut-on simplement lire sans rien consommer ?", a: "Bien sûr. Asseyez-vous, ouvrez un livre, restez le temps qu'il faut. Le café reste optionnel." },
    ],
  },
  {
    name: "Commander",
    slug: "commander",
    items: [
      { q: "Vendez-vous des livres en ligne ?", a: "Oui, l'intégralité du catalogue est commandable depuis le site. Paiement par CB ou PayPal." },
      { q: "Puis-je commander un livre absent du catalogue ?", a: "Oui, écrivez-nous le titre par email ou en boutique. Délai habituel de 48 à 72h pour les commandes éditeur." },
      { q: "Les prix en ligne et en boutique sont-ils identiques ?", a: "Oui, prix unique conforme à la loi Lang, hors livres anciens et occasions." },
      { q: "Proposez-vous des cartes cadeaux ?", a: "Oui, de 20 à 100€ ou montant libre, en version email instantanée ou carte papier livrée." },
      { q: "Les artisans sont-ils sourcés en Corse ?", a: "Tous nos artisans bougies, papeterie, savons sont insulaires et travaillent en circuit court." },
      { q: "Réservation possible avant déplacement ?", a: "Oui, par téléphone ou email. Nous mettons l'ouvrage de côté 48h." },
    ],
  },
  {
    name: "Livraison",
    slug: "livraison",
    items: [
      { q: "Quels modes de livraison proposez-vous ?", a: "Mondial Relay (4€90, 3 à 5 jours), Colissimo domicile (6€90, 2 à 3 jours), retrait en boutique gratuit." },
      { q: "Livrez-vous en dehors de la France ?", a: "Pas pour l'instant. Nous étudions une option européenne pour 2027." },
      { q: "Quel délai pour le retrait click & collect ?", a: "Dès le lendemain en boutique pour les ouvrages en stock, sous 72h pour le reste." },
      { q: "Comment suivre ma commande ?", a: "Un email vous est envoyé à chaque étape, avec un numéro de suivi cliquable." },
      { q: "Que faire en cas de colis abîmé ?", a: "Photographiez le colis avant ouverture et écrivez-nous : nous remplaçons sans question." },
      { q: "Puis-je retourner un livre ?", a: "Oui, sous 14 jours, dans son état d'origine, retour à votre charge sauf défaut." },
    ],
  },
  {
    name: "Café",
    slug: "cafe",
    items: [
      { q: "Servez-vous des boissons à emporter ?", a: "Oui, gobelet réutilisable consigné à 1€ ou apportez votre tasse pour -20 centimes." },
      { q: "Avez-vous des options sans lactose ?", a: "Oui : avoine, châtaigne, soja. Sans supplément." },
      { q: "Servez-vous à manger ?", a: "Pâtisseries maison, cookies, brownie, cake du jour. Pas de plat salé pour l'instant." },
      { q: "Le café est-il bio ?", a: "Notre torréfacteur ajaccien travaille en commerce équitable et certifie deux de ses cinq grains en bio." },
      { q: "Puis-je travailler depuis le café ?", a: "Oui, wifi gratuit, prises près des banquettes. Tarif découverte café à café après le 3ème." },
      { q: "Acceptez-vous les chèques restaurant ?", a: "Oui, papier et carte (Edenred, Swile, Up), sur place uniquement." },
    ],
  },
  {
    name: "Événements",
    slug: "evenements",
    items: [
      { q: "Comment s'inscrire à un événement ?", a: "Page événements, bouton inscription, paiement si payant. Confirmation par email." },
      { q: "Puis-je annuler mon inscription ?", a: "Oui, jusqu'à 48h avant, remboursement intégral. Au-delà, avoir valable un an." },
      { q: "Les enfants sont-ils acceptés ?", a: "Selon l'événement : chaque fiche précise l'âge minimum recommandé." },
      { q: "Organisez-vous des événements privés ?", a: "Oui, anniversaire, club lecture privé, formation, sur devis. Capacité 25 personnes." },
      { q: "Puis-je proposer un événement ?", a: "Oui, écrivez-nous une note d'intention. Nous y répondons toujours." },
      { q: "Les événements sont-ils filmés ?", a: "Jamais sans accord explicite. Aucune diffusion publique sans consentement écrit." },
    ],
  },
  {
    name: "Compte",
    slug: "compte",
    items: [
      { q: "Faut-il créer un compte pour commander ?", a: "Non, paiement invité disponible. Le compte permet juste de retrouver son historique." },
      { q: "Comment réinitialiser mon mot de passe ?", a: "Page connexion, lien Mot de passe oublié. Email de réinitialisation sous 5 minutes." },
      { q: "Comment supprimer mon compte ?", a: "Espace compte, RGPD, bouton Supprimer. Effet immédiat, données effacées sous 30 jours." },
      { q: "Recevez-vous des données via Stripe ou PayPal ?", a: "Seulement le minimum nécessaire à la commande. Aucune donnée bancaire stockée chez nous." },
      { q: "Programme de fidélité ?", a: "Oui : 1 café = 1 tampon, 10 tampons = 1 café offert. 1 livre = 1 tampon livre, 5 tampons = 5€ de bon." },
      { q: "Comment gérer la newsletter ?", a: "Lien de désinscription dans chaque envoi, ou Espace compte, Préférences." },
    ],
  },
];
---
<BaseLayout title="Questions fréquentes, Les Contes Infusés" description="Toutes les réponses à vos questions sur la librairie, le café, les commandes, les événements.">
  <section class="max-w-3xl mx-auto px-5 sm:px-8 pt-8 md:pt-16 pb-10 text-center">
    <p class="eyebrow"><span class="filet"></span><span class="mx-3">FAQ</span><span class="filet"></span></p>
    <h1 class="font-display italic text-5xl sm:text-7xl text-cocoa-600 mt-4">Questions fréquentes</h1>
    <p class="font-body italic text-cocoa-400 mt-6 text-lg">
      Cherchez un mot, dépliez une réponse. 36 questions classées en 6 catégories.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-5 sm:px-8 pb-20">
    <FaqSearch client:load categories={categories} />
  </section>

  <section class="max-w-3xl mx-auto px-5 sm:px-8 pb-24">
    <div class="bg-cream-100 border border-line rounded-2xl p-10 text-center">
      <p class="eyebrow">Pas trouvé ?</p>
      <p class="font-display italic text-3xl text-cocoa-600 mt-3">Écrivez-nous, on répond toujours.</p>
      <p class="font-body text-cocoa-700 mt-3">Sous 48h ouvrées, depuis Corte.</p>
      <a href="/contact" class="btn-terracotta mt-6"><Mail size={16} /> Nous contacter</a>
    </div>
  </section>
</BaseLayout>
