---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminEventRegistrations from "@/components/islands/admin/AdminEventRegistrations.tsx";
export const prerender = false;
const { event } = Astro.params;
---
<AuthGuard />
<AdminLayout title={`Inscrits ${event}, Admin`} section="evenements" breadcrumb={[{ label: "Événements", href: "/admin/evenements" }, { label: String(event) }]}>
  <header class="mb-7">
    <p class="eyebrow !text-[10px]">Inscriptions</p>
    <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Inscrits, {event}</h1>
  </header>
  <AdminEventRegistrations client:load slug={String(event)} />
</AdminLayout>
