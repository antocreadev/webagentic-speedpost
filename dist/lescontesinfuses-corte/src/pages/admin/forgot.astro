---
export const prerender = false;
import BaseLayout from "@/layouts/BaseLayout.astro";
import ForgotPasswordForm from "@/components/islands/ForgotPasswordForm.tsx";
---
<BaseLayout title="Mot de passe oublié, Les Contes Infusés" description="Récupération de votre mot de passe.">
  <section class="max-w-md mx-auto px-5 sm:px-8 py-12 md:py-16">
    <div class="text-center mb-8">
      <p class="eyebrow">Récupération</p>
      <h1 class="font-display italic text-4xl text-cocoa-600 mt-2">Mot de passe oublié</h1>
      <p class="text-sm text-cocoa-400 mt-3">Saisissez votre email, nous vous envoyons un lien sécurisé.</p>
    </div>
    <div class="bg-cream-50 border border-line rounded-2xl p-7 md:p-8">
      <ForgotPasswordForm client:load />
    </div>
    <p class="text-center text-xs text-cocoa-400 mt-5">
      <a href="/admin/login" class="underline">Retour à la connexion</a>
    </p>
  </section>
</BaseLayout>
