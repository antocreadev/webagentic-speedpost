---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminCustomersTable from "@/components/islands/admin/AdminCustomersTable.tsx";
export const prerender = false;
---
<AuthGuard />
<AdminLayout title="Clients, Admin" section="clients" breadcrumb={[{ label: "Clients" }]}>
  <header class="mb-7">
    <p class="eyebrow !text-[10px]">Base clients</p>
    <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Clients</h1>
    <p class="font-body text-cocoa-400 mt-1 text-sm">Liste des clients et fiches détaillées.</p>
  </header>
  <AdminCustomersTable client:load />
</AdminLayout>
