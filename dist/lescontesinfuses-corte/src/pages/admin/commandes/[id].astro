---
import AdminLayout from "@/layouts/AdminLayout.astro";
import LabelModal from "@/components/islands/LabelModal.tsx";
import { adminOrders } from "@/data/admin";
import { formatPrice, formatDate } from "@/lib/format";

export function getStaticPaths() {
  const ids = ["CI-2026-0001", "CI-2026-0002", "CI-2026-0003", "CI-2026-0042"];
  return ids.map(id => ({ params: { id } }));
}

const { id } = Astro.params;
const order = adminOrders.find(o => o.id === id) ?? adminOrders[0];

const subtotal = order.lines.reduce((s, l) => s + l.qty * l.unit, 0);
const delivery = order.delivery === "click" ? 0 : order.delivery === "domicile" ? 7.9 : 4.9;
const tva = +(subtotal * 0.055 + delivery * 0.20).toFixed(2);
const total = subtotal + delivery;

const timeline = [
  { date: "2026-04-20T09:12", label: "Commande passée par le client", actor: "Pierre Antonelli" },
  { date: "2026-04-20T09:14", label: "Paiement validé (Stripe, CB)", actor: "Système" },
  { date: "2026-04-20T09:30", label: "Email de confirmation envoyé", actor: "Système" },
  { date: "2026-04-20T10:05", label: "Commande prise en charge en boutique", actor: "Paul-Antoine" },
];

function statusChip(s: string) {
  if (s === "À traiter") return "bg-terracotta-50 text-terracotta-600 border-terracotta-200";
  if (s === "Préparée") return "bg-cream-200 text-cocoa-600 border-line";
  if (s === "Expédiée") return "bg-plum-200/60 text-plum-600 border-plum-200";
  return "bg-sage-200 text-sage-600 border-sage-400/40";
}

const tracking = order.tracking ?? "MR-2026-0099501";
---
<AdminLayout title={`${order.id}, Admin`} section="commandes" breadcrumb={[{ label: "Commandes", href: "/admin/commandes" }, { label: order.id }]}>
  <header class="flex flex-wrap items-end justify-between gap-4 mb-7">
    <div>
      <p class="eyebrow !text-[10px]">Commande</p>
      <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1 font-mono not-italic">{order.id}</h1>
      <p class="text-sm text-cocoa-400 font-sans mt-1">Passée le {formatDate(order.date, "long")}</p>
    </div>
    <span class={`chip border !text-sm !py-1.5 !px-3 ${statusChip(order.status)}`}>{order.status}</span>
  </header>

  <div class="grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <section class="bg-cream-50 border border-line rounded-xl p-6">
        <h2 class="font-display italic text-xl text-cocoa-700 mb-4">Articles</h2>
        <table class="w-full text-sm font-sans">
          <thead>
            <tr class="text-left text-[10px] uppercase tracking-widest text-cocoa-400 border-b border-line">
              <th class="py-2 pr-4 font-medium">Article</th>
              <th class="py-2 pr-4 font-medium text-right">Qté</th>
              <th class="py-2 pr-4 font-medium text-right">PU</th>
              <th class="py-2 font-medium text-right">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line">
            {order.lines.map(l => (
              <tr class="text-cocoa-700">
                <td class="py-3 pr-4">{l.title}</td>
                <td class="py-3 pr-4 text-right tabular-nums text-cocoa-400">{l.qty}</td>
                <td class="py-3 pr-4 text-right tabular-nums">{formatPrice(l.unit)}</td>
                <td class="py-3 text-right tabular-nums font-medium">{formatPrice(l.qty * l.unit)}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <div class="border-t border-line mt-4 pt-4 space-y-1.5 text-sm">
          <div class="flex justify-between text-cocoa-400"><span>Sous-total</span><span class="tabular-nums">{formatPrice(subtotal)}</span></div>
          <div class="flex justify-between text-cocoa-400"><span>Livraison</span><span class="tabular-nums">{delivery === 0 ? "Offerte" : formatPrice(delivery)}</span></div>
          <div class="flex justify-between text-cocoa-400 text-xs"><span>Dont TVA</span><span class="tabular-nums">{formatPrice(tva)}</span></div>
          <div class="flex justify-between font-display italic text-xl text-cocoa-700 pt-2 border-t border-dashed border-line"><span>Total TTC</span><span class="tabular-nums">{formatPrice(total)}</span></div>
        </div>
      </section>

      <section class="bg-cream-50 border border-line rounded-xl p-6">
        <h2 class="font-display italic text-xl text-cocoa-700 mb-4">Historique</h2>
        <ol class="space-y-4 relative">
          <span class="absolute left-1.5 top-2 bottom-2 w-px bg-line"></span>
          {timeline.map(t => (
            <li class="flex gap-4 pl-6 relative">
              <span class="absolute left-0 top-1.5 w-3 h-3 rounded-full bg-terracotta-400 border-2 border-cream-50"></span>
              <div class="flex-1">
                <p class="text-sm text-cocoa-700 font-sans">{t.label}</p>
                <p class="text-[11px] text-cocoa-400 mt-0.5 font-sans tabular-nums">{t.date} · {t.actor}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>
    </div>

    <aside class="space-y-6">
      <section class="bg-cream-50 border border-line rounded-xl p-6">
        <h2 class="font-display italic text-xl text-cocoa-700 mb-3">Client</h2>
        <p class="font-medium text-cocoa-700 text-sm">{order.customer}</p>
        <p class="text-sm text-cocoa-400">{order.email}</p>
        <p class="eyebrow !text-[10px] mt-5">Adresse de livraison</p>
        <p class="text-sm text-cocoa-700 mt-2 leading-snug">
          {order.address.street}<br />
          {order.address.zip} {order.address.city}
        </p>
      </section>

      <section class="bg-cream-50 border border-line rounded-xl p-6">
        <h2 class="font-display italic text-xl text-cocoa-700 mb-3">Expédition</h2>
        <p class="text-sm text-cocoa-700">Mode : {order.delivery === "click" ? "Click & Collect" : order.delivery === "domicile" ? "Domicile (Colissimo)" : "Mondial Relay"}</p>
        <label class="block mt-4 text-[10px] uppercase tracking-widest text-cocoa-400 font-sans">N° de suivi</label>
        <input type="text" value={tracking} class="mt-1 w-full px-3 py-2 bg-cream-100 border border-line rounded-md text-sm font-mono focus:outline-none focus:border-terracotta-400" />
        <div class="mt-5">
          <LabelModal client:idle orderId={order.id} tracking={tracking} customer={order.customer} street={order.address.street} zip={order.address.zip} city={order.address.city} />
        </div>
        <div class="grid grid-cols-2 gap-2 mt-3">
          <button type="button" class="btn-ghost !text-[11px] !py-2 !px-3 justify-center">Marquer préparée</button>
          <button type="button" class="btn-ghost !text-[11px] !py-2 !px-3 justify-center">Marquer expédiée</button>
        </div>
      </section>
    </aside>
  </div>
</AdminLayout>
