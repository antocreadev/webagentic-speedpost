---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminOrderDetail from "@/components/islands/admin/AdminOrderDetail.tsx";
export const prerender = false;
const { id } = Astro.params;
---
<AuthGuard />
<AdminLayout title={`Commande ${id}, Admin`} section="commandes" breadcrumb={[{ label: "Commandes", href: "/admin/commandes" }, { label: String(id) }]}>
  <AdminOrderDetail client:load id={String(id)} />
</AdminLayout>
