---
import AdminLayout from "@/layouts/AdminLayout.astro";
import LabelModal from "@/components/islands/LabelModal.tsx";
import Card from "@/components/admin/Card.astro";
import Chip from "@/components/admin/Chip.astro";
import { adminOrders } from "@/data/admin";
import { formatPrice, formatDate } from "@/lib/format";

export function getStaticPaths() {
  const ids = ["CI-2026-0001", "CI-2026-0002", "CI-2026-0003", "CI-2026-0042"];
  return ids.map(id => ({ params: { id } }));
}

const { id } = Astro.params;
const order = adminOrders.find(o => o.id === id) ?? adminOrders[0];

const subtotal = order.lines.reduce((s, l) => s + l.qty * l.unit, 0);
const delivery = order.delivery === "click" ? 0 : order.delivery === "domicile" ? 7.9 : 4.9;
const tva = +(subtotal * 0.055 + delivery * 0.20).toFixed(2);
const total = subtotal + delivery;

const activity = [
  { date: "20/04 09:12", label: "Commande passée par le client", actor: "Pierre Antonelli", tone: "info" },
  { date: "20/04 09:14", label: "Paiement validé (Stripe, CB ****1234)", actor: "Système", tone: "success" },
  { date: "20/04 09:30", label: "Email de confirmation envoyé", actor: "Système", tone: "info" },
  { date: "20/04 10:05", label: "Prise en charge en boutique", actor: "Paul-Antoine", tone: "warning" },
];

function statusTone(s: string): "success" | "warning" | "info" | "neutral" {
  if (s === "À traiter") return "warning";
  if (s === "Préparée") return "neutral";
  if (s === "Expédiée") return "info";
  return "success";
}

const tracking = order.tracking ?? "MR-2026-0099501";
---
<AdminLayout title={`${order.id}, Admin`} section="commandes" breadcrumb={[{ label: "Commandes", href: "/admin/commandes" }, { label: order.id }]}>
  <header class="flex flex-wrap items-end justify-between gap-4 mb-7">
    <div>
      <p class="eyebrow !text-[10px]">Commande</p>
      <h1 class="font-mono not-italic text-2xl md:text-3xl text-cocoa-700 mt-1 font-medium">{order.id}</h1>
      <p class="text-sm text-cocoa-400 font-sans mt-1">Passée le {formatDate(order.date, "long")}</p>
    </div>
    <div class="flex items-center gap-2">
      <Chip tone={statusTone(order.status)} dot>{order.status}</Chip>
      <button type="button" class="btn-ghost !py-2 !px-4 !text-[11px]">Imprimer la facture</button>
    </div>
  </header>

  <div class="grid lg:grid-cols-[1fr_320px] gap-6">
    <div class="space-y-6 min-w-0">
      <Card>
        <div slot="header">
          <h2 class="font-display italic text-xl text-cocoa-700">Articles</h2>
        </div>
        <table class="w-full text-sm font-sans -mt-3">
          <thead>
            <tr class="text-left text-[10px] uppercase tracking-widest text-cocoa-400 border-b border-line">
              <th class="py-2 pr-4 font-medium">Article</th>
              <th class="py-2 pr-4 font-medium text-right">Qté</th>
              <th class="py-2 pr-4 font-medium text-right">PU</th>
              <th class="py-2 font-medium text-right">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line">
            {order.lines.map(l => (
              <tr class="text-cocoa-700">
                <td class="py-3 pr-4">{l.title}</td>
                <td class="py-3 pr-4 text-right tabular-nums text-cocoa-400">{l.qty}</td>
                <td class="py-3 pr-4 text-right tabular-nums">{formatPrice(l.unit)}</td>
                <td class="py-3 text-right tabular-nums font-medium">{formatPrice(l.qty * l.unit)}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <div class="border-t border-line mt-4 pt-4 space-y-1.5 text-sm">
          <div class="flex justify-between text-cocoa-400"><span>Sous-total</span><span class="tabular-nums">{formatPrice(subtotal)}</span></div>
          <div class="flex justify-between text-cocoa-400"><span>Livraison</span><span class="tabular-nums">{delivery === 0 ? "Offerte" : formatPrice(delivery)}</span></div>
          <div class="flex justify-between text-cocoa-400 text-xs"><span>Dont TVA</span><span class="tabular-nums">{formatPrice(tva)}</span></div>
          <div class="flex justify-between font-display italic text-xl text-cocoa-700 pt-2 border-t border-dashed border-line"><span>Total TTC</span><span class="tabular-nums">{formatPrice(total)}</span></div>
        </div>
      </Card>

      <Card>
        <div slot="header" class="flex items-center justify-between">
          <h2 class="font-display italic text-xl text-cocoa-700">Client</h2>
          <a href="/admin/clients" class="text-xs text-terracotta-400 hover:text-cocoa-700 font-smallcap uppercase tracking-widest">Fiche complète</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <p class="font-medium text-cocoa-700">{order.customer}</p>
            <a href={`mailto:${order.email}`} class="text-sm text-cocoa-400 hover:text-terracotta-400">{order.email}</a>
            <p class="eyebrow !text-[10px] mt-4">Adresse de livraison</p>
            <p class="text-sm text-cocoa-700 mt-1.5 leading-snug">
              {order.address.street}<br />
              {order.address.zip} {order.address.city}
            </p>
          </div>
          <div>
            <p class="eyebrow !text-[10px]">Expédition</p>
            <p class="text-sm text-cocoa-700 mt-1.5">{order.delivery === "click" ? "Click & Collect, à retirer en boutique" : order.delivery === "domicile" ? "Domicile, Colissimo" : "Mondial Relay"}</p>
            <label class="block mt-3 text-[10px] uppercase tracking-widest text-cocoa-400 font-sans">N° de suivi</label>
            <input type="text" value={tracking} class="mt-1 w-full px-3 py-2 bg-cream-100 border border-line rounded-md text-sm font-mono focus:outline-none focus:border-terracotta-400" />
          </div>
        </div>
        <div class="mt-5 flex flex-wrap gap-2">
          <LabelModal client:idle orderId={order.id} tracking={tracking} customer={order.customer} street={order.address.street} zip={order.address.zip} city={order.address.city} />
          <button type="button" class="btn-ghost !py-2 !px-4 !text-[11px]">Marquer préparée</button>
          <button type="button" class="btn-ghost !py-2 !px-4 !text-[11px]">Marquer expédiée</button>
          <button type="button" class="btn-ghost !py-2 !px-4 !text-[11px]">Renvoyer email confirmation</button>
        </div>
      </Card>
    </div>

    <aside class="lg:sticky lg:top-20 self-start space-y-5">
      <Card padded={false}>
        <div slot="header" class="flex items-center justify-between">
          <h2 class="font-display italic text-xl text-cocoa-700">Fil d'activité</h2>
          <Chip tone="info">{activity.length}</Chip>
        </div>
        <ol class="relative px-6 py-5">
          <span class="absolute left-[26px] top-7 bottom-7 w-px bg-line" aria-hidden="true"></span>
          {activity.map(a => (
            <li class="relative pl-8 pb-4 last:pb-0">
              <span class:list={[
                "absolute left-0 top-1 inline-flex h-4 w-4 items-center justify-center rounded-full border-2 border-cream-50",
                a.tone === "success" && "bg-sage-400",
                a.tone === "warning" && "bg-terracotta-400",
                a.tone === "info" && "bg-plum-400",
                a.tone === "neutral" && "bg-cocoa-200",
              ]}></span>
              <p class="text-sm text-cocoa-700 font-sans leading-snug">{a.label}</p>
              <p class="text-[11px] text-cocoa-400 mt-0.5 font-sans tabular-nums">{a.date} · {a.actor}</p>
            </li>
          ))}
        </ol>
        <div slot="footer">
          <form id="lci-note-form" class="flex flex-col gap-2">
            <label class="font-smallcap text-[10px] uppercase tracking-windier text-cocoa-400">Note interne</label>
            <textarea
              name="note"
              rows="2"
              placeholder="Ajouter une note pour l'équipe..."
              class="w-full px-3 py-2 bg-cream-50 border border-line rounded-md text-sm font-sans focus:outline-none focus:border-terracotta-400 resize-none"
            ></textarea>
            <button type="submit" class="self-end btn-ghost !py-1.5 !px-3 !text-[10px]">Ajouter au fil</button>
          </form>
        </div>
      </Card>
    </aside>
  </div>

  <script is:inline>
    document.getElementById("lci-note-form")?.addEventListener("submit", (e) => {
      e.preventDefault();
      const t = e.target.note.value.trim();
      if (!t) return;
      window.__lciToast?.success("Note ajoutée au fil d'activité", t.slice(0, 60));
      e.target.reset();
    });
  </script>
</AdminLayout>
