---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminOrdersTable from "@/components/islands/admin/AdminOrdersTable.tsx";
export const prerender = false;
---
<AuthGuard />
<AdminLayout title="Commandes, Admin" section="commandes" breadcrumb={[{ label: "Commandes" }]}>
  <header class="flex items-end justify-between gap-4 mb-7 flex-wrap">
    <div>
      <p class="eyebrow !text-[10px]">Suivi</p>
      <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Commandes</h1>
      <p class="font-body text-cocoa-400 mt-1 text-sm">Toutes les commandes du backend, filtrables et exportables.</p>
    </div>
  </header>
  <AdminOrdersTable client:load />
</AdminLayout>
