---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Chip from "@/components/admin/Chip.astro";
import { adminOrders } from "@/data/admin";
import { formatPrice, formatDate } from "@/lib/format";

function statusTone(s: string): "success" | "warning" | "info" | "neutral" {
  if (s === "À traiter") return "warning";
  if (s === "Préparée") return "neutral";
  if (s === "Expédiée") return "info";
  return "success";
}

const url = new URL(Astro.request.url);
const filter = url.searchParams.get("statut") ?? "tous";
const page = Math.max(1, parseInt(url.searchParams.get("page") ?? "1", 10));
const PAGE_SIZE = 10;

const filtered = filter === "tous" ? adminOrders : adminOrders.filter(o => o.status.toLowerCase() === filter);
const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
const pageRows = filtered.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);

const statusFilters = [
  { id: "tous", label: "Tous", count: adminOrders.length },
  { id: "à traiter", label: "À traiter", count: adminOrders.filter(o => o.status === "À traiter").length },
  { id: "préparée", label: "Préparées", count: adminOrders.filter(o => o.status === "Préparée").length },
  { id: "expédiée", label: "Expédiées", count: adminOrders.filter(o => o.status === "Expédiée").length },
  { id: "livrée", label: "Livrées", count: adminOrders.filter(o => o.status === "Livrée").length },
];

const deliveryIcon: Record<string, string> = {
  relais: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4v-8H10v8H6a2 2 0 0 1-2-2z"/>',
  domicile: '<path d="m1 3 22 0"/><path d="M5 3v18h14V3"/><path d="M9 12h6"/>',
  click: '<rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21v-4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v4"/>',
};
const deliveryLabel: Record<string, string> = { relais: "Mondial Relay", domicile: "Domicile", click: "Click & Collect" };
---
<AdminLayout title="Commandes, Admin" section="commandes" breadcrumb={[{ label: "Commandes" }]}>
  <header class="flex items-end justify-between gap-4 mb-7 flex-wrap">
    <div>
      <p class="eyebrow !text-[10px]">Gestion</p>
      <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Commandes</h1>
      <p class="font-body text-cocoa-400 mt-1 text-sm">{filtered.length} commandes affichées, page {page} sur {totalPages}.</p>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" class="btn-ghost !py-2 !px-4 !text-[11px]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Exporter CSV
      </button>
      <button type="button" class="btn-terracotta !py-2 !px-4 !text-[11px]">Nouvelle commande</button>
    </div>
  </header>

  <div class="mb-5 flex flex-wrap items-center gap-2">
    {statusFilters.map(s => (
      <a
        href={s.id === "tous" ? "/admin/commandes" : `/admin/commandes?statut=${encodeURIComponent(s.id)}`}
        class:list={[
          "inline-flex items-center gap-2 rounded-full border px-3.5 py-1.5 font-sans text-[12px] transition-colors",
          filter === s.id
            ? "bg-cocoa-700 text-cream-50 border-cocoa-700"
            : "bg-cream-50 text-cocoa-700 border-line hover:border-terracotta-400/60",
        ]}
      >
        {s.label}
        <span class:list={[
          "rounded-full px-1.5 py-px text-[10px] font-sans tabular-nums",
          filter === s.id ? "bg-cream-50/15 text-cream-100" : "bg-cream-100 text-cocoa-400",
        ]}>{s.count}</span>
      </a>
    ))}
    <div class="ml-auto flex items-center gap-2 px-3 h-9 bg-cream-50 border border-line rounded-full w-72">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="search" placeholder="Numéro, client, ville..." class="bg-transparent outline-none text-sm flex-1 font-sans placeholder:text-cocoa-400/70" />
    </div>
  </div>

  {/* Bulk action bar (hidden until selection) */}
  <div id="lci-bulk-bar" class="hidden mb-3 flex items-center gap-3 rounded-xl border border-terracotta-200 bg-terracotta-50/60 px-4 py-2.5 font-sans text-sm">
    <span class="text-cocoa-700"><span id="lci-bulk-count" class="font-medium">0</span> sélectionnée(s)</span>
    <div class="ml-auto flex items-center gap-2">
      <button type="button" class="btn-ghost !py-1.5 !px-3 !text-[10px]">Marquer expédiées</button>
      <button type="button" class="btn-ghost !py-1.5 !px-3 !text-[10px]">Imprimer étiquettes</button>
      <button type="button" class="btn-ghost !py-1.5 !px-3 !text-[10px]">Exporter sélection</button>
    </div>
  </div>

  <div class="overflow-hidden rounded-xl border border-line bg-cream-50">
    <div class="overflow-x-auto">
      <table id="orders-tbl" class="w-full min-w-[900px] font-sans text-sm">
        <thead class="border-b border-line bg-cream-100/60">
          <tr class="text-left font-smallcap text-[10px] uppercase tracking-windier text-cocoa-400">
            <th class="w-8 px-4 py-3"><input type="checkbox" id="select-all-orders" class="h-4 w-4 accent-terracotta-400" aria-label="Tout sélectionner" /></th>
            <th class="px-4 py-3 font-medium"><button type="button" data-sort="id" class="inline-flex items-center gap-1 hover:text-cocoa-700">N° <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg></button></th>
            <th class="px-4 py-3 font-medium"><button type="button" data-sort="date" class="inline-flex items-center gap-1 hover:text-cocoa-700">Date</button></th>
            <th class="px-4 py-3 font-medium">Client</th>
            <th class="px-4 py-3 font-medium">Articles</th>
            <th class="px-4 py-3 font-medium"><button type="button" data-sort="total" class="inline-flex items-center gap-1 hover:text-cocoa-700">Total</button></th>
            <th class="px-4 py-3 font-medium">Livraison</th>
            <th class="px-4 py-3 font-medium">Statut</th>
            <th class="px-4 py-3 font-medium text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line">
          {pageRows.map(o => (
            <tr class="text-cocoa-700 hover:bg-cream-100/50 transition-colors">
              <td class="w-8 px-4 py-3"><input type="checkbox" class="lci-row-select h-4 w-4 accent-terracotta-400" /></td>
              <td class="px-4 py-3 font-mono text-xs"><a href={`/admin/commandes/${o.id}`} class="hover:text-terracotta-400">{o.id}</a></td>
              <td class="px-4 py-3 text-xs text-cocoa-400 tabular-nums whitespace-nowrap">{formatDate(o.date, "short")}</td>
              <td class="px-4 py-3">{o.customer}</td>
              <td class="px-4 py-3 tabular-nums text-cocoa-400 text-xs">{o.items}</td>
              <td class="px-4 py-3 tabular-nums font-medium">{formatPrice(o.total)}</td>
              <td class="px-4 py-3 text-cocoa-400">
                <span class="inline-flex items-center gap-1.5 text-xs">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={deliveryIcon[o.delivery]} />
                  {deliveryLabel[o.delivery]}
                </span>
              </td>
              <td class="px-4 py-3"><Chip tone={statusTone(o.status)} dot>{o.status}</Chip></td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-end gap-1 text-cocoa-400">
                  <a href={`/admin/commandes/${o.id}`} aria-label="Voir" class="p-1.5 hover:text-terracotta-400 hover:bg-cream-100 rounded transition-colors">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                  </a>
                  <button type="button" aria-label="Préparer" class="p-1.5 hover:text-terracotta-400 hover:bg-cream-100 rounded transition-colors">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="M3.3 7 12 12l8.7-5"/><path d="M12 22V12"/></svg>
                  </button>
                  <button type="button" aria-label="Modifier" class="p-1.5 hover:text-terracotta-400 hover:bg-cream-100 rounded transition-colors">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="flex items-center justify-between border-t border-line px-4 py-3 bg-cream-100/40">
      <p class="font-sans text-xs text-cocoa-400 tabular-nums">
        {(page - 1) * PAGE_SIZE + 1} - {Math.min(page * PAGE_SIZE, filtered.length)} sur {filtered.length}
      </p>
      <nav class="flex items-center gap-1" aria-label="Pagination">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
          <a
            href={`?statut=${filter}&page=${p}`}
            class:list={[
              "inline-flex h-8 min-w-[32px] items-center justify-center rounded-md font-sans text-xs px-2 transition-colors",
              p === page ? "bg-cocoa-700 text-cream-50" : "text-cocoa-400 hover:bg-cream-100 hover:text-cocoa-700",
            ]}
          >{p}</a>
        ))}
      </nav>
    </div>
  </div>

  <script is:inline>
    (() => {
      const tbl = document.getElementById("orders-tbl");
      if (!tbl) return;
      const all = document.getElementById("select-all-orders");
      const rows = () => tbl.querySelectorAll(".lci-row-select");
      const bar = document.getElementById("lci-bulk-bar");
      const count = document.getElementById("lci-bulk-count");
      function refresh() {
        const c = tbl.querySelectorAll(".lci-row-select:checked").length;
        if (count) count.textContent = String(c);
        if (bar) bar.classList.toggle("hidden", c === 0);
      }
      all?.addEventListener("change", (e) => {
        rows().forEach((cb) => { cb.checked = e.target.checked; });
        refresh();
      });
      tbl.addEventListener("change", (e) => {
        if (e.target && e.target.classList && e.target.classList.contains("lci-row-select")) refresh();
      });
      // simple sort
      let lastKey = ""; let dir = 1;
      tbl.querySelectorAll("[data-sort]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const tbody = tbl.querySelector("tbody");
          if (!tbody) return;
          const key = btn.getAttribute("data-sort");
          const colMap = { id: 1, date: 2, total: 5 };
          const idx = colMap[key];
          if (idx == null) return;
          if (lastKey === key) dir = -dir; else { lastKey = key; dir = 1; }
          const rs = Array.from(tbody.querySelectorAll("tr"));
          rs.sort((a, b) => {
            const av = a.children[idx]?.textContent?.trim() || "";
            const bv = b.children[idx]?.textContent?.trim() || "";
            const an = parseFloat(av.replace(/[^0-9,.\-]/g, "").replace(",", "."));
            const bn = parseFloat(bv.replace(/[^0-9,.\-]/g, "").replace(",", "."));
            if (!isNaN(an) && !isNaN(bn)) return (an - bn) * dir;
            return av.localeCompare(bv, "fr") * dir;
          });
          rs.forEach((r) => tbody.appendChild(r));
        });
      });
    })();
  </script>
</AdminLayout>
