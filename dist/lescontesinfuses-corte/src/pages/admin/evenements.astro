---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminEventsCalendar from "@/components/islands/admin/AdminEventsCalendar.tsx";
export const prerender = false;
---
<AuthGuard />
<AdminLayout title="Événements, Admin" section="evenements" breadcrumb={[{ label: "Événements" }]}>
  <header class="mb-7">
    <p class="eyebrow !text-[10px]">Programmation</p>
    <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Événements</h1>
    <p class="font-body text-cocoa-400 mt-1 text-sm">Calendrier, jauges, accès aux inscrits.</p>
  </header>
  <AdminEventsCalendar client:load />
</AdminLayout>
