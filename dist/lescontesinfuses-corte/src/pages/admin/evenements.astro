---
import AdminLayout from "@/layouts/AdminLayout.astro";
import EventCalendar from "@/components/islands/EventCalendar.tsx";
import { events } from "@/data/events";
import { formatDate } from "@/lib/format";

// Map events to current month (April 2026) deterministically
const calEvents = [
  { slug: "dedicace-marcu-biancarelli", title: "Dédicace Biancarelli", day: 9, hour: "18:00", registered: 22, capacity: 40 },
  { slug: "club-lecture-mai", title: "Club lecture", day: 16, hour: "17:00", registered: 12, capacity: 16 },
  { slug: "atelier-ecriture-ados", title: "Atelier d'écriture ados", day: 22, hour: "14:30", registered: 6, capacity: 10 },
  { slug: "soiree-contes-corses", title: "Soirée contes corses", day: 30, hour: "20:30", registered: 31, capacity: 50 },
  { slug: "lecture-publique-poesie", title: "Lecture publique poésie", day: 5, hour: "18:30", registered: 0, capacity: 80 },
  { slug: "concert-acoustique-guitare", title: "Concert acoustique", day: 12, hour: "20:00", registered: 9, capacity: 30 },
];

const upcoming = events.slice(0, 5);
---
<AdminLayout title="Événements, Admin" section="evenements" breadcrumb={[{ label: "Événements" }]}>
  <header class="flex items-end justify-between gap-4 mb-7 flex-wrap">
    <div>
      <p class="eyebrow !text-[10px]">Programmation</p>
      <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Événements</h1>
      <p class="font-body text-cocoa-400 mt-1 text-sm">Cliquez un jour pour créer, cliquez un événement pour modifier.</p>
    </div>
  </header>

  <div class="grid lg:grid-cols-[1fr_320px] gap-6">
    <EventCalendar client:idle events={calEvents} />

    <aside class="bg-cream-50 border border-line rounded-xl p-5 self-start">
      <h2 class="font-display italic text-xl text-cocoa-700 mb-4">Prochains événements</h2>
      <ul class="space-y-3">
        {upcoming.map(e => (
          <li class="p-3 rounded-lg bg-cream-100/60 border border-line">
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1 min-w-0">
                <p class="font-display italic text-sm text-cocoa-700 leading-tight">{e.title}</p>
                <p class="text-[11px] text-cocoa-400 mt-0.5 font-sans tabular-nums">{formatDate(e.date, "short")} · {e.registered}/{e.capacity}</p>
              </div>
              <div class="flex items-center gap-0.5 text-cocoa-400 shrink-0">
                <a href={`/admin/inscriptions/${e.slug}`} aria-label="Inscrits" class="p-1 hover:text-terracotta-400 rounded">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                </a>
                <button aria-label="Modifier" class="p-1 hover:text-terracotta-400 rounded">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg>
                </button>
                <button aria-label="Supprimer" class="p-1 hover:text-terracotta-600 rounded">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
                </button>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</AdminLayout>
