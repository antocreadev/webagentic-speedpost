---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminLabelsQueue from "@/components/islands/admin/AdminLabelsQueue.tsx";
export const prerender = false;
---
<AuthGuard />
<AdminLayout title="Étiquettes, Admin" section="etiquettes" breadcrumb={[{ label: "Catalogue" }, { label: "Étiquettes" }]}>
  <header class="mb-7">
    <p class="eyebrow !text-[10px]">Expéditions</p>
    <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">File d'étiquettes</h1>
    <p class="font-body text-cocoa-400 mt-1 text-sm">Commandes payées et en préparation, prêtes à imprimer en lot.</p>
  </header>
  <AdminLabelsQueue client:load />
</AdminLayout>
