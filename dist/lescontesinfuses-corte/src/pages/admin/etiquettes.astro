---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { adminOrders } from "@/data/admin";

// Pick 8 orders awaiting label print
const queue = adminOrders.slice(0, 8).map((o, i) => ({
  ...o,
  weight: (0.4 + (i * 0.13) % 1.6).toFixed(3),
  tracking: o.tracking ?? `MR-2026-00${(98000 + i * 137) % 100000}`,
}));
---
<AdminLayout title="Étiquettes, Admin" section="etiquettes" breadcrumb={[{ label: "Étiquettes" }]}>
  <header class="flex items-end justify-between gap-4 mb-7 flex-wrap">
    <div>
      <p class="eyebrow !text-[10px]">File d'attente</p>
      <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Étiquettes à imprimer</h1>
      <p class="font-body text-cocoa-400 mt-1 text-sm">{queue.length} bordereaux Mondial Relay et Colissimo en attente.</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <button type="button" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
        Marquer expédié
      </button>
      <button type="button" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"/><rect x="6" y="14" width="12" height="8" rx="1"/></svg>
        Imprimer la sélection
      </button>
      <button type="button" class="btn-terracotta">
        Tout imprimer ({queue.length})
      </button>
    </div>
  </header>

  <div class="bg-cream-50 border border-line rounded-xl overflow-hidden">
    <div class="px-5 py-3 border-b border-line bg-cream-100/40 flex items-center gap-3 text-xs">
      <input type="checkbox" class="accent-terracotta-400 w-4 h-4" />
      <span class="text-cocoa-400 uppercase tracking-widest font-sans">Tout sélectionner</span>
    </div>
    <ul class="divide-y divide-line">
      {queue.map(q => (
        <li class="px-5 py-4 flex items-center gap-4 hover:bg-cream-100/30">
          <input type="checkbox" class="accent-terracotta-400 w-4 h-4" />

          <div class="shrink-0 w-20 h-12 bg-white border border-cocoa-700 rounded-sm flex flex-col p-1 overflow-hidden relative">
            <div class="flex items-center gap-1">
              <svg width="10" height="10" viewBox="0 0 42 42" aria-hidden="true">
                <rect width="42" height="42" rx="4" fill="#E2001A" />
                <text x="21" y="29" textAnchor="middle" fill="#fff" fontSize="20" fontWeight="700" fontFamily="Inter">MR</text>
              </svg>
              <div class="flex-1 grid grid-cols-12 gap-px h-2 mt-px">
                {Array.from({ length: 12 }, (_, i) => <span class={`bg-cocoa-700 ${i % 3 === 0 ? "h-2" : "h-1.5"}`}></span>)}
              </div>
            </div>
            <div class="grid grid-cols-5 gap-px mt-1 grow">
              {Array.from({ length: 25 }, (_, i) => <span class={`${(i * 7 + 3) % 3 === 0 ? "bg-cocoa-700" : "bg-transparent"}`}></span>)}
            </div>
          </div>

          <div class="flex-1 min-w-0">
            <p class="font-mono text-xs text-cocoa-700">{q.id}</p>
            <p class="text-sm text-cocoa-700 mt-0.5">{q.customer}, {q.address.city} ({q.address.zip})</p>
            <p class="text-[11px] text-cocoa-400 font-sans tabular-nums mt-0.5">{q.tracking} · {q.weight} kg · {q.delivery === "domicile" ? "Colissimo" : "Mondial Relay"}</p>
          </div>

          <div class="shrink-0 flex items-center gap-2">
            <a href={`/admin/commandes/${q.id}`} class="text-xs text-terracotta-400 hover:text-cocoa-700 font-sans uppercase tracking-widest">Voir</a>
            <button type="button" class="px-3 py-1.5 text-[11px] uppercase tracking-widest font-smallcap rounded-md border border-line hover:border-terracotta-400 hover:text-terracotta-400 text-cocoa-700">Imprimer</button>
          </div>
        </li>
      ))}
    </ul>
  </div>
</AdminLayout>
