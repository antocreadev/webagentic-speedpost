---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Stat from "@/components/admin/Stat.astro";
import Card from "@/components/admin/Card.astro";
import Chart from "@/components/admin/Chart.astro";
import Chip from "@/components/admin/Chip.astro";
import { adminOrders } from "@/data/admin";
import { events } from "@/data/events";
import { formatPrice, formatDate } from "@/lib/format";

const sparkOrders = [4, 6, 5, 8, 7, 9, 8];
const sparkRevenue = [320, 410, 380, 520, 600, 540, 720];
const sparkInscr = [12, 15, 14, 18, 17, 20, 23];
const sparkStock = [8, 7, 6, 5, 4, 4, 4];

// 30 days mock heights
const monthly = [42, 28, 51, 33, 47, 58, 71, 35, 24, 49, 62, 80, 55, 41, 38, 44, 67, 73, 52, 36, 29, 47, 61, 78, 84, 59, 43, 50, 66, 74];
const weekly = [44, 67, 73, 52, 84, 59, 50];
const weekLabels = ["Lun", "Mar", "Mer", "Jeu", "Ven", "Sam", "Dim"];

const last5 = adminOrders.slice(0, 5);
const todos = [
  { label: "Préparer 8 commandes en attente d'expédition", urgent: true },
  { label: "Relancer 3 fournisseurs en retard (Albiana, Actes Sud, Gallimard)", urgent: false },
  { label: "Confirmer la jauge de la soirée contes (capacité 50, 31 inscrits)", urgent: false },
  { label: "Réapprovisionner Mémoires d'Hadrien (stock à 3)", urgent: true },
];

function statusTone(s: string): "success" | "warning" | "info" | "neutral" {
  if (s === "À traiter") return "warning";
  if (s === "Préparée") return "neutral";
  if (s === "Expédiée") return "info";
  return "success";
}

const upcomingEvents = events.slice(0, 3);
---
<AdminLayout title="Tableau de bord, Admin" section="dashboard">
  <header class="mb-8 flex items-end justify-between gap-4 flex-wrap">
    <div>
      <p class="eyebrow !text-[10px]">Vue générale</p>
      <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Bonjour Paul-Antoine</h1>
      <p class="font-body text-cocoa-400 mt-1 text-sm">Lundi 20 avril 2026, 09h12. Café tiède, journée chargée.</p>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" class="btn-ghost !py-2 !px-4 !text-[11px]">Cette semaine</button>
      <button type="button" class="btn-terracotta !py-2 !px-4 !text-[11px]">Composer une newsletter</button>
    </div>
  </header>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <Stat eyebrow="Commandes du jour" value="8" delta={{ value: "+33%", trend: "up" }} hint="vs hier" spark={sparkOrders} tone="terracotta" />
    <Stat eyebrow="CA du mois" value="4 280 €" delta={{ value: "+12%", trend: "up" }} hint="vs mars" spark={sparkRevenue} tone="sage" />
    <Stat eyebrow="Inscriptions événements" value="23" delta={{ value: "+5", trend: "up" }} hint="5 événements actifs" spark={sparkInscr} tone="plum" />
    <Stat eyebrow="Stock en alerte" value="4" delta={{ value: "-1", trend: "down" }} hint="livres sous le seuil" spark={sparkStock} tone="cocoa" />
  </div>

  <div class="grid lg:grid-cols-3 gap-6 mb-8">
    <Card className="lg:col-span-2">
      <div slot="header" class="flex items-center justify-between flex-wrap gap-2">
        <div>
          <p class="eyebrow !text-[10px]">Activité, 30 derniers jours</p>
          <h2 class="font-display italic text-2xl text-cocoa-700 mt-0.5">Commandes par jour</h2>
        </div>
        <div class="flex items-center gap-2">
          <Chip tone="warning" dot>Pic le 14 avril</Chip>
          <Chip tone="success">+18% sur la période</Chip>
        </div>
      </div>
      <Chart type="bar" data={monthly} labels={["21 mars", "5 avril", "20 avril"]} height={170} />
    </Card>

    <Card tone="dark" className="text-cream-100">
      <div slot="header">
        <p class="eyebrow !text-cream-100/60 !text-[10px]">À faire aujourd'hui</p>
        <h2 class="font-display italic text-2xl text-cream-50 mt-0.5">4 priorités</h2>
      </div>
      <ul class="space-y-3">
        {todos.map(t => (
          <li class="flex items-start gap-3">
            <input type="checkbox" class="mt-1 accent-terracotta-400 w-4 h-4 shrink-0" />
            <span class={`text-sm leading-snug ${t.urgent ? "text-cream-50" : "text-cream-100/75"}`}>
              {t.urgent && <span class="inline-block w-1.5 h-1.5 rounded-full bg-terracotta-400 mr-1.5 align-middle"></span>}
              {t.label}
            </span>
          </li>
        ))}
      </ul>
    </Card>
  </div>

  <div class="grid lg:grid-cols-2 gap-6 mb-8">
    <Card>
      <div slot="header" class="flex items-center justify-between">
        <div>
          <p class="eyebrow !text-[10px]">Aperçu hebdo</p>
          <h2 class="font-display italic text-2xl text-cocoa-700 mt-0.5">Ventes 7 derniers jours</h2>
        </div>
        <Chip tone="info" dot>Tendance haussière</Chip>
      </div>
      <Chart type="line" data={weekly} labels={weekLabels} height={170} color="#8E6C90" />
    </Card>

    <Card>
      <div slot="header" class="flex items-center justify-between">
        <div>
          <p class="eyebrow !text-[10px]">Cette semaine</p>
          <h2 class="font-display italic text-2xl text-cocoa-700 mt-0.5">Événements à venir</h2>
        </div>
        <a href="/admin/evenements" class="text-xs uppercase tracking-widest text-terracotta-400 hover:text-cocoa-700 font-smallcap">Tout voir</a>
      </div>
      <ul class="divide-y divide-line -mt-3">
        {upcomingEvents.map(e => {
          const ratio = e.registered / e.capacity;
          const tone: "success" | "warning" | "danger" = ratio >= 0.85 ? "danger" : ratio >= 0.5 ? "warning" : "success";
          return (
            <li class="flex items-center gap-4 py-3">
              <div class="w-12 h-12 rounded-lg bg-cream-100 border border-line flex flex-col items-center justify-center shrink-0">
                <span class="font-display italic text-lg leading-none text-cocoa-700 tabular-nums">{formatDate(e.date, "day")}</span>
                <span class="font-smallcap text-[9px] uppercase tracking-windier text-cocoa-400 mt-0.5">{formatDate(e.date, "month")}</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-display italic text-base text-cocoa-700 truncate">{e.title}</p>
                <p class="text-[11px] text-cocoa-400 font-sans tabular-nums">{e.location}</p>
                <div class="mt-1.5 flex items-center gap-2">
                  <div class="flex-1 h-1 rounded-full bg-cream-100 overflow-hidden">
                    <span class:list={[
                      "block h-full rounded-full",
                      tone === "success" && "bg-sage-400",
                      tone === "warning" && "bg-terracotta-400",
                      tone === "danger" && "bg-terracotta-600",
                    ]} style={`width: ${Math.min(ratio * 100, 100)}%`}></span>
                  </div>
                  <span class="text-[11px] tabular-nums text-cocoa-400">{e.registered}/{e.capacity}</span>
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    </Card>
  </div>

  <Card>
    <div slot="header" class="flex items-center justify-between">
      <div>
        <p class="eyebrow !text-[10px]">Activité récente</p>
        <h2 class="font-display italic text-2xl text-cocoa-700 mt-0.5">Dernières commandes</h2>
      </div>
      <a href="/admin/commandes" class="text-xs uppercase tracking-widest text-terracotta-400 hover:text-cocoa-700 font-smallcap">Voir tout</a>
    </div>
    <div class="overflow-x-auto -mt-3">
      <table class="w-full text-sm font-sans">
        <thead>
          <tr class="text-left text-[10px] uppercase tracking-widest text-cocoa-400 border-b border-line">
            <th class="py-2 pr-4 font-medium">N°</th>
            <th class="py-2 pr-4 font-medium">Client</th>
            <th class="py-2 pr-4 font-medium">Articles</th>
            <th class="py-2 pr-4 font-medium">Total</th>
            <th class="py-2 font-medium">Statut</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line">
          {last5.map(o => (
            <tr class="text-cocoa-700 hover:bg-cream-100/40 transition-colors">
              <td class="py-3 pr-4 font-mono text-xs"><a href={`/admin/commandes/${o.id}`} class="hover:text-terracotta-400">{o.id}</a></td>
              <td class="py-3 pr-4">{o.customer}</td>
              <td class="py-3 pr-4 tabular-nums text-xs text-cocoa-400">{o.items}</td>
              <td class="py-3 pr-4 tabular-nums">{formatPrice(o.total)}</td>
              <td class="py-3"><Chip tone={statusTone(o.status)} dot>{o.status}</Chip></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Card>
</AdminLayout>
