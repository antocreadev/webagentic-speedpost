---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminDashboard from "@/components/islands/admin/AdminDashboard.tsx";
export const prerender = false;
---
<AuthGuard />
<AdminLayout title="Tableau de bord, Admin" section="dashboard">
  <header class="mb-8">
    <p class="eyebrow !text-[10px]">Vue générale</p>
    <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Bonjour</h1>
    <p class="font-body text-cocoa-400 mt-1 text-sm">Données en direct depuis le backend.</p>
  </header>
  <AdminDashboard client:load />
</AdminLayout>
