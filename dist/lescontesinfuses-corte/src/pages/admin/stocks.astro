---
import AdminLayout from "@/layouts/AdminLayout.astro";
import Card from "@/components/admin/Card.astro";
import Chip from "@/components/admin/Chip.astro";
import { books } from "@/data/books";

function stockTone(s: number): "success" | "warning" | "danger" {
  if (s < 3) return "danger";
  if (s <= 10) return "warning";
  return "success";
}

const steps = [
  {
    id: 1,
    title: "Configuration",
    description: "Renseigner les identifiants LibriSoft, choisir le format (CSV horaire ou API REST), valider le mapping ISBN.",
    progress: 30,
    state: "active" as const,
  },
  {
    id: 2,
    title: "Test de connexion",
    description: "Lancer un import à blanc et vérifier la cohérence des références sur 50 titres pilotes.",
    progress: 0,
    state: "pending" as const,
  },
  {
    id: 3,
    title: "Synchronisation automatique",
    description: "Activer le cron horaire et les notifications de divergence stock.",
    progress: 0,
    state: "pending" as const,
  },
];
---
<AdminLayout title="Stocks, Admin" section="stocks" breadcrumb={[{ label: "Catalogue" }, { label: "Stocks" }]}>
  <header class="mb-7 flex items-end justify-between gap-4 flex-wrap">
    <div>
      <p class="eyebrow !text-[10px]">Inventaire</p>
      <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Stocks</h1>
      <p class="font-body text-cocoa-400 mt-1 text-sm">{books.length} références suivies, dont {books.filter(b => b.stock < 3).length} en alerte basse.</p>
    </div>
    <button type="button" class="btn-ghost !py-2 !px-4 !text-[11px]">Inventaire complet</button>
  </header>

  <Card tone="dark" className="mb-7 text-cream-100" padded={false}>
    <div class="px-6 pt-5 pb-2">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <p class="font-smallcap text-[10px] uppercase tracking-windier text-cream-100/60">Intégration</p>
          <h2 class="font-display italic text-2xl text-cream-50 mt-0.5">Raccord LibriSoft</h2>
          <p class="font-sans text-sm text-cream-100/75 mt-1 max-w-xl">
            Synchronisez votre logiciel de gestion en trois étapes. Format CSV horaire ou API REST, nous nous chargeons du paramétrage technique.
          </p>
        </div>
        <Chip tone="warning" dot>1 / 3 en cours</Chip>
      </div>
    </div>
    <ol class="px-6 py-6 grid md:grid-cols-3 gap-5 relative">
      {steps.map((s, i) => (
        <li class="relative">
          {i < steps.length - 1 && (
            <span class="hidden md:block absolute top-3.5 -right-3 w-6 h-px bg-cream-100/15" aria-hidden="true"></span>
          )}
          <div class="flex items-center gap-2">
            <span class:list={[
              "inline-flex h-7 w-7 items-center justify-center rounded-full font-mono text-xs font-medium",
              s.state === "active" ? "bg-terracotta-400 text-cream-50" : "bg-cream-100/10 text-cream-100/60",
            ]}>{s.id}</span>
            <p class="font-display italic text-base text-cream-50">{s.title}</p>
          </div>
          <p class="mt-2 text-[12px] leading-snug text-cream-100/65 font-sans">{s.description}</p>
          <div class="mt-3 h-1 rounded-full bg-cream-100/10 overflow-hidden">
            <span
              class:list={["block h-full rounded-full transition-all", s.state === "active" ? "bg-terracotta-400" : "bg-cream-100/15"]}
              style={`width:${s.progress}%`}
            ></span>
          </div>
          <p class="mt-1.5 font-mono text-[10px] text-cream-100/50 tabular-nums">{s.progress}%</p>
        </li>
      ))}
    </ol>
    <div class="border-t border-cream-100/10 px-6 py-3 flex items-center justify-between flex-wrap gap-2 bg-cocoa-800/30">
      <div class="flex items-center gap-3">
        <button type="button" role="switch" aria-checked="false" class="w-11 h-6 rounded-full p-0.5 bg-cream-100/15" disabled>
          <span class="block w-5 h-5 rounded-full bg-cream-100/40"></span>
        </button>
        <span class="text-sm text-cream-100/75">Synchronisation auto, désactivée</span>
        <span class="text-xs text-cream-100/45">Dernière sync : aucune</span>
      </div>
      <div class="flex items-center gap-2">
        <button type="button" class="btn-ghost !py-1.5 !px-3 !text-[10px] !text-cream-100 !border-cream-100/30 hover:!border-terracotta-400 hover:!text-terracotta-200">Voir la documentation</button>
        <button type="button" class="btn-terracotta !py-1.5 !px-3 !text-[10px]">Continuer la configuration</button>
      </div>
    </div>
  </Card>

  <div class="bg-cream-50 border border-line rounded-xl p-4 mb-5 flex flex-wrap items-center gap-3">
    <span class="text-[10px] uppercase tracking-widest text-cocoa-400 font-sans">Filtrer par seuil</span>
    <button type="button" class="chip !text-terracotta-600 !border-terracotta-200 !bg-terracotta-50">Critique (&lt; 3)</button>
    <button type="button" class="chip">3 à 10</button>
    <button type="button" class="chip">&gt; 10</button>
  </div>

  <div class="bg-cream-50 border border-line rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm font-sans min-w-[800px]">
        <thead class="bg-cream-100/60 border-b border-line">
          <tr class="text-left text-[10px] uppercase tracking-widest text-cocoa-400">
            <th class="px-4 py-3 font-medium w-12">Visuel</th>
            <th class="px-4 py-3 font-medium">Titre</th>
            <th class="px-4 py-3 font-medium">Auteur</th>
            <th class="px-4 py-3 font-medium">ISBN</th>
            <th class="px-4 py-3 font-medium">Stock</th>
            <th class="px-4 py-3 font-medium text-right">Ajuster</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line">
          {books.map(b => (
            <tr class="text-cocoa-700 hover:bg-cream-100/40 transition-colors">
              <td class="px-4 py-3">
                <div class="w-8 h-11 rounded-sm shadow-sm" style={`background: linear-gradient(135deg, ${b.coverGradient[0]}, ${b.coverGradient[1]});`}></div>
              </td>
              <td class="px-4 py-3 font-medium">{b.title}</td>
              <td class="px-4 py-3 text-cocoa-400">{b.author}</td>
              <td class="px-4 py-3 text-xs font-mono text-cocoa-400">{b.isbn}</td>
              <td class="px-4 py-3"><Chip tone={stockTone(b.stock)} dot>{b.stock}</Chip></td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-end gap-2">
                  <input type="number" value={b.stock} class="w-16 px-2 py-1 bg-cream-100 border border-line rounded-md text-sm font-sans text-right tabular-nums focus:outline-none focus:border-terracotta-400" />
                  <button type="button" class="px-3 py-1 text-[11px] uppercase tracking-widest font-smallcap rounded-md border border-line hover:border-terracotta-400 hover:text-terracotta-400 text-cocoa-700">Enregistrer</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
