---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminStocks from "@/components/islands/admin/AdminStocks.tsx";
export const prerender = false;
---
<AuthGuard />
<AdminLayout title="Stocks, Admin" section="stocks" breadcrumb={[{ label: "Catalogue" }, { label: "Stocks" }]}>
  <header class="mb-7">
    <p class="eyebrow !text-[10px]">Catalogue</p>
    <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Stocks</h1>
    <p class="font-body text-cocoa-400 mt-1 text-sm">Synchronisation LibriSoft, alertes seuil bas.</p>
  </header>
  <AdminStocks client:load />
</AdminLayout>
