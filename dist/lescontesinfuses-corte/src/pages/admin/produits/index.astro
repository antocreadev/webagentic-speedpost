---
import AdminLayout from "@/layouts/AdminLayout.astro";
import AuthGuard from "@/components/AuthGuard.astro";
import AdminProductsTable from "@/components/islands/admin/AdminProductsTable.tsx";
export const prerender = false;
---
<AuthGuard />
<AdminLayout title="Produits, Admin" section="produits" breadcrumb={[{ label: "Produits" }]}>
  <header class="flex items-end justify-between gap-4 mb-7 flex-wrap">
    <div>
      <p class="eyebrow !text-[10px]">Catalogue</p>
      <h1 class="font-display italic text-3xl md:text-4xl text-cocoa-700 mt-1">Livres et artisans</h1>
      <p class="font-body text-cocoa-400 mt-1 text-sm">Gestion du catalogue, en direct du backend.</p>
    </div>
  </header>
  <AdminProductsTable client:load />
</AdminLayout>
