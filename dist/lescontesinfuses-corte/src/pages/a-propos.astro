---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LaurelBranch from "@/components/icons/LaurelBranch.astro";
import LaceMedallion from "@/components/icons/LaceMedallion.astro";
import Teapot from "@/components/icons/Teapot.astro";
import Quill from "@/components/icons/Quill.astro";

const chapters = [
  {
    nb: "I",
    title: "L'idée",
    body: "Tout commence en 2024, à la table d'une cuisine de Bastia, autour d'un café qui refroidissait. On parlait des librairies qu'on aimait, celles de Lyon, de Naples, de Pise. On se disait : pourquoi pas Corte ? Pourquoi pas un endroit où l'on pourrait lire vraiment, lentement, en posant sa tasse sans craindre de tacher la page. L'idée a tenu six mois avant d'avoir un nom.",
  },
  {
    nb: "II",
    title: "Le lieu",
    body: "Place Paoli, deuxième vitrine en partant de la fontaine, ancienne mercerie. Murs en pierre apparente, plancher de châtaignier vieux de cent ans, mezzanine en bois qui craque exactement comme on l'espérait. Il a fallu un an pour le trouver. Six mois pour signer le bail. Quatre mois pour rénover, en gardant tout ce qui pouvait l'être. La verrière du fond donne sur la cour intérieure et la lumière y entre toute la journée.",
  },
  {
    nb: "III",
    title: "Les livres",
    body: "Notre fonds de mille deux cents titres tient en trois principes. Premièrement, des classiques qu'on aime relire et qu'on défend. Deuxièmement, une vraie place pour la littérature corse contemporaine, en français et en lingua corsa. Troisièmement, des coups de cœur assumés, parfois discrets, parfois iconoclastes, mais toujours tenus.",
  },
  {
    nb: "IV",
    title: "Le café",
    body: "Le café est servi par Saveriu, formé à Naples, qui prend son métier exactement aussi au sérieux qu'on prend les nôtres. Le grain vient d'un torréfacteur ajaccien. Le lait châtaigne est notre signature. La pâtisserie change chaque semaine selon ce que Letizia trouve au marché. On peut s'asseoir trois heures avec un seul cappuccino, c'est même encouragé.",
  },
  {
    nb: "V",
    title: "L'équipe",
    body: "Nous sommes quatre : Anna à la sélection des livres, Saveriu au comptoir, Letizia à la cuisine, Paul-Antoine aux soirées contes et événements. Quatre personnes, c'est exactement la bonne taille pour faire les choses bien et garder le sourire jusqu'au samedi soir.",
  },
];
---
<BaseLayout
  title="Notre histoire, Les Contes Infusés"
  description="L'histoire d'une librairie indépendante et d'un café au pied de la citadelle de Corte. De l'idée première à l'ouverture, en cinq chapitres."
>
  {/* HERO MAGAZINE drop-cap */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-50">
      <div class="absolute -top-10 -right-32 w-[480px]">
        <LaurelBranch size={480} flip />
      </div>
    </div>
    <div class="relative max-w-4xl mx-auto px-5 sm:px-8 pt-8 md:pt-16 pb-12">
      <p class="eyebrow text-center"><span class="filet"></span><span class="mx-3">À propos</span><span class="filet"></span></p>
      <h1 class="font-display italic text-5xl sm:text-7xl md:text-8xl text-cocoa-600 text-center leading-[0.95] mt-6">
        Une maison<br/>de papier et de grain
      </h1>
      <p class="font-script text-3xl text-terracotta-400 text-center mt-6">Notre histoire, en cinq chapitres.</p>
    </div>
  </section>

  {/* INTRO + drop-cap */}
  <section class="max-w-3xl mx-auto px-5 sm:px-8 py-16">
    <div class="flex justify-center mb-8 opacity-70"><Teapot size={56} /></div>
    <p class="font-body text-lg leading-[1.85] text-cocoa-700">
      <span class="float-left font-display italic text-[6.5rem] leading-[0.85] text-terracotta-400 mr-3 mt-1">L</span>
      es Contes Infusés sont nés d'une conversation lente, d'une envie tenace, et d'un local qu'il a fallu attendre. Cette page raconte le chemin, sans rien embellir et sans rien taire d'essentiel. Si vous avez le temps, prenez-le : c'est un texte qui se lit comme on prend un thé, en posant la tasse entre les paragraphes.
    </p>
  </section>

  {/* CHAPTERS, alternating layouts */}
  {chapters.map((c, i) => (
    <section class={`relative py-16 ${i % 2 === 1 ? "bg-cream-100/60" : ""}`}>
      <div class="max-w-6xl mx-auto px-5 sm:px-8">
        <div class={`grid md:grid-cols-12 gap-10 items-center ${i % 2 === 1 ? "md:[&>*:first-child]:order-2" : ""}`}>
          <div class="md:col-span-7" data-reveal>
            <p class="eyebrow">Chapitre {c.nb}</p>
            <h2 class="font-display italic text-4xl sm:text-5xl text-cocoa-600 mt-3">{c.title}</h2>
            <span class="filet w-32 mt-4 block"></span>
            <p class="mt-6 font-body text-cocoa-700 leading-[1.85] text-base sm:text-lg">{c.body}</p>
          </div>
          <div class="md:col-span-5" data-reveal>
            <div class="aspect-[4/5] rounded-2xl shadow-page relative overflow-hidden" style={`background: linear-gradient(135deg, ${i === 0 ? "#F7EFD8, #C9A37D" : i === 1 ? "#5C3820, #3A2014" : i === 2 ? "#C77A4F, #9A4F2A" : i === 3 ? "#8A9876, #5A6647" : "#8E6C90, #5E456A"})`}>
              <div class="absolute inset-6 border border-cream-50/30 rounded-xl"></div>
              <div class="absolute inset-10 border border-cream-50/15 rounded-lg border-dashed"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="font-display italic text-[10rem] text-cream-50/15 select-none">{c.nb}</span>
              </div>
              <div class="absolute bottom-6 left-6 right-6">
                <p class="font-script text-xl text-cream-100">{c.title}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  {/* MANIFESTO full-bleed italic */}
  <section class="bg-ink text-cream-100 py-24 my-12">
    <div class="max-w-3xl mx-auto px-5 sm:px-8 text-center">
      <p class="eyebrow text-cream-100/50"><span class="filet"></span><span class="mx-3">Manifesto</span><span class="filet"></span></p>
      <p class="font-display italic text-3xl sm:text-4xl md:text-5xl leading-[1.3] mt-8">
        Une librairie indépendante au pied de la citadelle de Corte. Un café qui sent le grain et le papier. Des livres qu'on choisit avec lenteur, parce qu'ici on prend le temps.
      </p>
      <p class="font-script text-3xl text-terracotta-200 mt-10">Lire, infuser, recommencer.</p>
    </div>
  </section>

  {/* PINYON QUOTE */}
  <section class="max-w-3xl mx-auto px-5 sm:px-8 py-16 text-center">
    <div class="flex justify-center mb-8"><LaceMedallion size={90} /></div>
    <p class="font-script text-4xl sm:text-5xl text-cocoa-600 leading-[1.4]">
      « On ouvre un livre comme on pousse une porte. »
    </p>
    <p class="mt-6 eyebrow">Anna Filippi, libraire</p>
  </section>

  {/* TIMELINE */}
  <section class="max-w-4xl mx-auto px-5 sm:px-8 py-20">
    <p class="eyebrow text-center"><span class="filet"></span><span class="mx-3">Repères</span><span class="filet"></span></p>
    <h2 class="font-display italic text-4xl sm:text-5xl text-cocoa-600 text-center mt-4 mb-16">Trois années, trois étapes</h2>

    <div class="relative">
      <div class="absolute left-1/2 top-0 bottom-0 w-px bg-line hidden md:block"></div>
      {[
        { year: "2024", title: "L'idée", text: "Premières discussions, choix du nom, dépôt de marque." },
        { year: "2025", title: "Recherche locale", text: "Bail signé Place Paoli. Rencontre des artisans. Constitution du fonds." },
        { year: "2026", title: "Ouverture", text: "Aménagement, formation barista, premiers événements. Vous êtes ici." },
      ].map((s, i) => (
        <div class={`md:grid md:grid-cols-2 md:gap-12 mb-12 last:mb-0 items-center ${i % 2 === 1 ? "md:[&>*:first-child]:order-2" : ""}`}>
          <div class={`${i % 2 === 1 ? "md:text-left md:pl-10" : "md:text-right md:pr-10"}`}>
            <p class="font-display italic text-6xl text-terracotta-400">{s.year}</p>
          </div>
          <div class={`relative ${i % 2 === 1 ? "md:pr-10 md:text-right" : "md:pl-10"}`}>
            <span class="hidden md:block absolute top-4 w-3 h-3 rounded-full bg-terracotta-400 ring-4 ring-cream-50" style={`${i % 2 === 1 ? "right: -7px;" : "left: -7px;"}`}></span>
            <p class="font-display text-2xl text-cocoa-600">{s.title}</p>
            <p class="font-body text-cocoa-700 mt-2">{s.text}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="text-center pb-24">
    <a href="/equipe" class="btn-terracotta">Rencontrer l'équipe</a>
  </section>
</BaseLayout>
