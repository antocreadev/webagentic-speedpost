---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { MapPin } from "lucide-react";

const partners = [
  { name: "Fromagerie Casanova", trade: "Fromages corses", x: 220, y: 140, distance: "80 m", color: "#8A9876", note: "Brocciu, casgiu merzu, tommes affinées." },
  { name: "Torréfaction U Grano", trade: "Torréfacteur", x: 380, y: 100, distance: "180 m", color: "#5C3820", note: "Notre fournisseur principal de café." },
  { name: "Cave Vinili", trade: "Caviste", x: 320, y: 230, distance: "140 m", color: "#8E6C90", note: "Vins corses indépendants, biodynamie." },
  { name: "Papeterie Ricciu", trade: "Papeterie d'art", x: 450, y: 200, distance: "260 m", color: "#C77A4F", note: "Carnets, encres, plumes, cartes pliées." },
  { name: "Chocolaterie Bicchu", trade: "Chocolats artisanaux", x: 180, y: 280, distance: "320 m", color: "#7C4F31", note: "Tablettes au myrte, bouchées chataîgne." },
  { name: "Pâtisserie Filippi", trade: "Pâtisserie", x: 500, y: 310, distance: "420 m", color: "#E2B594", note: "Le maître pâtissier qui forme Letizia." },
];
---
<BaseLayout title="Réseau partenaires Corte, Les Contes Infusés" description="Six commerces partenaires à Corte, à 5 minutes à pied de la librairie.">
  <section class="max-w-5xl mx-auto px-5 sm:px-8 pt-8 md:pt-16 pb-10 text-center">
    <p class="eyebrow"><span class="filet"></span><span class="mx-3">Réseau partenaires</span><span class="filet"></span></p>
    <h1 class="font-display italic text-5xl sm:text-7xl text-cocoa-600 mt-4">Le quartier qu'on aime</h1>
    <p class="font-body italic text-cocoa-400 max-w-2xl mx-auto mt-6 text-lg">
      Six commerces à 5 minutes à pied. On leur apporte des clients, ils nous prêtent une farine, un crémant, une tablette de chocolat. Voilà.
    </p>
  </section>

  {/* MAP SVG */}
  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-10">
    <div class="rounded-3xl bg-cream-100 border border-line overflow-hidden shadow-page">
      <svg viewBox="0 0 600 400" class="w-full h-auto" role="img" aria-label="Carte simplifiée du centre de Corte">
        <rect width="600" height="400" fill="#F7EFD8" />
        {/* Streets */}
        <g stroke="#D9C8A8" strokeWidth="14" fill="none">
          <path d="M 0 200 L 600 200" />
          <path d="M 280 0 L 280 400" />
          <path d="M 100 80 L 540 320" />
        </g>
        <g stroke="#FBF6E9" strokeWidth="2" strokeDasharray="6 8" fill="none">
          <path d="M 0 200 L 600 200" />
          <path d="M 280 0 L 280 400" />
        </g>
        {/* Citadelle motif */}
        <g opacity="0.35" fill="none" stroke="#7C4F31" strokeWidth="1.2">
          <path d="M 30 30 L 60 30 L 60 50 L 75 50 L 75 30 L 105 30 L 105 70 L 30 70 Z" />
          <text x="120" y="55" fontFamily="Cormorant Garamond" fontStyle="italic" fontSize="14" fill="#7C4F31">Citadelle</text>
        </g>
        {/* Les Contes Infusés (anchor) */}
        <g>
          <circle cx="280" cy="200" r="14" fill="#C77A4F" />
          <circle cx="280" cy="200" r="22" fill="none" stroke="#C77A4F" strokeDasharray="2 3" />
          <text x="280" y="178" textAnchor="middle" fontFamily="Cormorant SC" fontSize="9" letterSpacing="2" fill="#4A2D1F">LES CONTES INFUSÉS</text>
          <text x="280" y="244" textAnchor="middle" fontFamily="Cormorant Garamond" fontStyle="italic" fontSize="11" fill="#7C4F31">Place Paoli</text>
        </g>
        {/* Partner pins */}
        {partners.map((p, i) => (
          <g>
            <circle cx={p.x} cy={p.y} r="9" fill={p.color} />
            <circle cx={p.x} cy={p.y} r="14" fill="none" stroke={p.color} strokeWidth="1" opacity="0.5" />
            <text x={p.x} y={p.y+4} textAnchor="middle" fontFamily="Inter" fontSize="9" fontWeight="600" fill="#FBF6E9">{i+1}</text>
            <text x={p.x} y={p.y-18} textAnchor="middle" fontFamily="Cormorant Garamond" fontStyle="italic" fontSize="11" fill="#4A2D1F">{p.name}</text>
          </g>
        ))}
      </svg>
    </div>
    <p class="text-center mt-4 text-xs font-sans text-cocoa-400 italic">Plan simplifié, pas à l'échelle. Distances réelles indiquées sous chaque fiche.</p>
  </section>

  {/* CARDS */}
  <section class="max-w-6xl mx-auto px-5 sm:px-8 py-12 pb-24">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {partners.map((p, i) => (
        <article class="bg-cream-50 rounded-2xl border border-line p-7 flex flex-col" data-reveal>
          <div class="flex items-start justify-between">
            <div class="w-12 h-12 rounded-full flex items-center justify-center font-display italic text-xl text-cream-50" style={`background:${p.color}`}>{i+1}</div>
            <span class="chip"><MapPin size={12} /> {p.distance}</span>
          </div>
          {/* Logo SVG */}
          <svg viewBox="0 0 160 50" class="mt-4 w-full max-w-[160px]">
            <text x="80" y="28" textAnchor="middle" fontFamily="Cormorant Garamond" fontStyle="italic" fontSize="20" fill={p.color}>{p.name.split(" ")[0]}</text>
            <line x1="30" y1="36" x2="130" y2="36" stroke={p.color} strokeWidth="0.5" />
            <text x="80" y="46" textAnchor="middle" fontFamily="Cormorant SC" fontSize="6" letterSpacing="2.5" fill={p.color}>{p.trade.toUpperCase()}</text>
          </svg>
          <h2 class="font-display italic text-2xl text-cocoa-600 mt-4">{p.name}</h2>
          <p class="text-xs font-smallcap tracking-windier uppercase text-cocoa-400 mt-1">{p.trade}</p>
          <p class="font-body text-cocoa-700 text-sm mt-3 flex-1">{p.note}</p>
          <a href="#" class="mt-5 inline-flex items-center gap-2 font-smallcap text-xs tracking-widest uppercase text-terracotta-600 hover:text-cocoa-600 transition">Voir la fiche</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
