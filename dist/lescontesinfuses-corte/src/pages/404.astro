---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LaceMedallion from "@/components/icons/LaceMedallion.astro";
import LaurelBranch from "@/components/icons/LaurelBranch.astro";
---
<BaseLayout
  title="Page introuvable, Les Contes Infusés"
  description="Cette page s'est égarée dans les rayons. Trouvez votre prochain chapitre."
>
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-50">
      <LaceMedallion size={620} />
    </div>

    <div class="relative max-w-3xl mx-auto px-5 sm:px-8 py-16 text-center">
      <p class="eyebrow"><span class="filet"></span><span class="mx-3">Erreur 404</span><span class="filet"></span></p>
      <h1 class="font-display italic text-5xl md:text-7xl text-cocoa-600 mt-4 leading-[0.95]">
        Cette page s'est égarée dans les rayons.
      </h1>
      <p class="font-body text-cocoa-400 mt-5 text-base md:text-lg max-w-xl mx-auto">
        Peut-être trouverez-vous votre bonheur dans notre catalogue, notre carte café ou nos événements.
      </p>

      <div class="flex justify-center my-8 opacity-90">
        <svg width="220" height="120" viewBox="0 0 220 120" fill="none" aria-hidden="true">
          <defs>
            <linearGradient id="lci-404-book" x1="0" x2="1" y1="0" y2="1">
              <stop offset="0%" stop-color="#C77A4F"/>
              <stop offset="100%" stop-color="#9A4F2A"/>
            </linearGradient>
          </defs>
          <rect x="60" y="20" width="80" height="14" rx="1" fill="url(#lci-404-book)" stroke="#4A2D1F" stroke-width="0.8"/>
          <rect x="55" y="34" width="90" height="14" rx="1" fill="#8A9876" stroke="#4A2D1F" stroke-width="0.8"/>
          <rect x="62" y="48" width="76" height="14" rx="1" fill="#E5CDB1" stroke="#4A2D1F" stroke-width="0.8"/>
          <rect x="58" y="62" width="84" height="14" rx="1" fill="#8E6C90" stroke="#4A2D1F" stroke-width="0.8"/>
          <g transform="translate(150 80) rotate(18)">
            <rect x="0" y="0" width="60" height="14" rx="1" fill="#C9A37D" stroke="#4A2D1F" stroke-width="0.8"/>
            <line x1="6" y1="7" x2="54" y2="7" stroke="#4A2D1F" stroke-width="0.6" stroke-dasharray="2 2"/>
          </g>
          <g transform="translate(170 70) rotate(-32)">
            <path d="M0 0 Q 18 -8, 30 -2 L 28 4 Q 14 -2, 0 6 Z" fill="#FBF6E9" stroke="#4A2D1F" stroke-width="0.8"/>
            <line x1="2" y1="3" x2="26" y2="0" stroke="#4A2D1F" stroke-width="0.5"/>
          </g>
        </svg>
      </div>

      <form action="/recherche" method="get" class="mt-2 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <label for="lci-404-q" class="sr-only">Rechercher</label>
        <input
          id="lci-404-q"
          name="q"
          type="search"
          placeholder="Un titre, un auteur, un thé..."
          class="flex-1 px-5 py-3 rounded-full border border-line bg-paper text-cocoa-700 placeholder:text-cocoa-200 placeholder:italic focus:outline-none focus:border-terracotta-400 font-sans text-sm"
        />
        <button type="submit" class="btn-terracotta justify-center">Chercher</button>
      </form>

      <div class="mt-12 grid sm:grid-cols-3 gap-4 text-left">
        <a href="/livres" class="group block bg-cream-50 border border-line rounded-2xl p-5 hover:border-terracotta-400 hover:-translate-y-0.5 transition-all duration-200">
          <p class="eyebrow">Catalogue</p>
          <p class="font-display italic text-xl text-cocoa-600 mt-1.5 group-hover:text-terracotta-400 transition-colors">Parcourir les livres</p>
          <p class="text-sm text-cocoa-400 mt-2">Romans corses, beaux-arts, jeunesse, poche.</p>
        </a>
        <a href="/cafe" class="group block bg-cream-50 border border-line rounded-2xl p-5 hover:border-terracotta-400 hover:-translate-y-0.5 transition-all duration-200">
          <p class="eyebrow">Café</p>
          <p class="font-display italic text-xl text-cocoa-600 mt-1.5 group-hover:text-terracotta-400 transition-colors">Voir la carte</p>
          <p class="text-sm text-cocoa-400 mt-2">Thés, cafés de spécialité, douceurs maison.</p>
        </a>
        <a href="/evenements" class="group block bg-cream-50 border border-line rounded-2xl p-5 hover:border-terracotta-400 hover:-translate-y-0.5 transition-all duration-200">
          <p class="eyebrow">Agenda</p>
          <p class="font-display italic text-xl text-cocoa-600 mt-1.5 group-hover:text-terracotta-400 transition-colors">Événements</p>
          <p class="text-sm text-cocoa-400 mt-2">Dédicaces, club lecture, contes, concerts.</p>
        </a>
      </div>

      <div class="mt-14 flex flex-col items-center gap-3">
        <div class="opacity-60">
          <LaurelBranch size={120} />
        </div>
        <a href="/" class="font-smallcap uppercase tracking-widest text-xs text-cocoa-400 hover:text-terracotta-400 transition-colors">
          Retour à l'accueil
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
