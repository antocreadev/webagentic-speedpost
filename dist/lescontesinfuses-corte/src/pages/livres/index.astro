---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LaceMedallion from "@/components/icons/LaceMedallion.astro";
import BookCatalog from "@/components/islands/BookCatalog.tsx";
import { books } from "@/data/books";
import { genres } from "@/data/genres";
---
<BaseLayout
  title="La bibliothèque, catalogue, Les Contes Infusés"
  description="Tous les livres de la librairie : 24 titres à Corte, romans, polars, BD, beaux-livres, jeunesse, poésie, Corse."
>
  <section class="relative">
    <div class="absolute inset-x-0 top-0 h-72 bg-cream-100/40 border-b border-line pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-7xl mx-auto px-5 sm:px-8 pt-10 pb-6 text-center">
      <div class="flex justify-center mb-4 opacity-70">
        <LaceMedallion size={84} />
      </div>
      <p class="eyebrow">
        <span class="filet"></span>
        <span class="mx-3">Catalogue</span>
        <span class="filet"></span>
      </p>
      <h1 class="font-display italic text-5xl md:text-7xl text-cocoa-600 mt-4 leading-[0.95]">
        La bibliothèque
      </h1>
      <p class="font-body italic text-cocoa-400 mt-4 max-w-xl mx-auto">
        Vingt-quatre titres choisis avec lenteur. Romans, poésie, beaux-livres, voix corses. Ce que nous aurions envie de vous tendre, en main propre.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-5 sm:px-8 py-12">
    <BookCatalog books={books} genres={genres} client:load />
  </section>
</BaseLayout>
