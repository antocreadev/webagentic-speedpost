---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LaceMedallion from "@/components/icons/LaceMedallion.astro";
import ArtisansFilter from "@/components/islands/ArtisansFilter.tsx";
import { artisans } from "@/data/artisans";

const portraits = [
  { name: "Atelier Sì", city: "Calenzana", body: "Cire végétale, mèches en bois, parfums tirés du maquis. Trois personnes, un atelier sous figuier, et l'envie de faire durer." },
  { name: "Maroquinerie Petralba", city: "Aleria", body: "Cuirs tannés au végétal, gravures à chaud. Une famille, trois générations. Une signature lente." },
  { name: "Terra Forme", city: "Pigna", body: "Céramiques émaillées à la main, formes inspirées des pierres polies du Tavignano. Petite production, beaucoup d'âme." },
];
---
<BaseLayout
  title="L'atelier des artisans corses, Les Contes Infusés"
  description="Bougies, papeterie, céramique, textile, soin, épicerie. Sélection d'artisans corses chez Les Contes Infusés."
>
  <section class="relative max-w-6xl mx-auto px-5 sm:px-8 pt-14 pb-12 text-center" data-chapter="1">
    <div class="flex justify-center mb-6 opacity-80" data-parallax="0.3">
      <LaceMedallion size={140} />
    </div>
    <p class="eyebrow" data-reveal data-fade-direction="up"><span class="filet"></span><span class="mx-3">L'atelier</span><span class="filet"></span></p>
    <h1 class="font-display italic text-5xl md:text-8xl text-cocoa-600 mt-4 leading-[0.95]" data-reveal data-fade-direction="scale">
      Faits ici, à la main
    </h1>
    <p class="font-body italic text-cocoa-400 mt-6 max-w-2xl mx-auto text-lg" data-reveal data-fade-direction="up" style="transition-delay:120ms">
      Bougies, marque-pages, céramiques. Des objets sélectionnés un à un chez les artisans corses qui partagent notre amour du beau et du juste.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-5 sm:px-8 pb-20" data-chapter="2">
    <ArtisansFilter products={artisans} client:load />
  </section>

  <section class="bg-cream-100/40 border-y border-line py-20" data-chapter="3">
    <div class="max-w-5xl mx-auto px-5 sm:px-8">
      <header class="text-center mb-12">
        <p class="eyebrow">Rencontre</p>
        <h2 class="font-display italic text-4xl md:text-5xl text-cocoa-600 mt-2">Trois mains, trois villages</h2>
      </header>
      <div class="grid md:grid-cols-3 gap-6" data-stagger="100">
        {portraits.map((p) => (
          <article class="bg-cream-50 border border-line rounded-2xl p-6">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-terracotta-200 to-cocoa-200 mb-4"></div>
            <p class="eyebrow">{p.city}</p>
            <h3 class="font-display italic text-2xl text-cocoa-600 mt-1">{p.name}</h3>
            <p class="text-sm text-cocoa-700 mt-3 leading-relaxed">{p.body}</p>
            <a href="#" class="mt-4 inline-flex items-center gap-1.5 text-xs font-smallcap tracking-widest uppercase text-terracotta-600 hover:text-cocoa-600">
              Lire la rencontre →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
