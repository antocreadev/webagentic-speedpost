---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CheckoutFlow from "@/components/islands/CheckoutFlow.tsx";
---
<BaseLayout title="Commander, Les Contes Infusés" description="Tunnel de paiement sécurisé en quatre étapes : coordonnées, livraison, paiement, confirmation.">
  <section class="max-w-6xl mx-auto px-5 sm:px-8 py-12 md:py-16">
    <header class="mb-10 text-center">
      <p class="eyebrow"><span class="filet"></span><span class="mx-3">Passage en commande</span><span class="filet"></span></p>
      <h1 class="font-display italic text-4xl md:text-5xl text-cocoa-600 mt-3">Quelques pas vers la lecture</h1>
      <p class="font-body italic text-cocoa-400 mt-3 max-w-xl mx-auto">Renseignez vos coordonnées, choisissez votre mode de remise, réglez en toute sécurité.</p>
    </header>
    <CheckoutFlow client:idle />
  </section>
</BaseLayout>
