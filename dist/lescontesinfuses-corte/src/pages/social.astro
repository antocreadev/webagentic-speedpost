---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SocialTabs from "@/components/islands/SocialTabs.tsx";
---
<BaseLayout
  title="Réseaux sociaux, Les Contes Infusés"
  description="Le mur Instagram et Facebook de la librairie-café à Corte."
>
  <section class="max-w-5xl mx-auto px-5 sm:px-8 pt-14 pb-12 text-center">
    <p class="eyebrow"><span class="filet"></span><span class="mx-3">En ligne</span><span class="filet"></span></p>
    <h1 class="font-display italic text-5xl md:text-7xl text-cocoa-600 mt-4 leading-[0.95]">
      Suivez la maison
    </h1>
    <p class="font-body italic text-cocoa-400 mt-4 max-w-xl mx-auto">
      Les rayons à l'aube, la machine qui fume, les visages des auteurs invités, et tout ce qu'on n'a pas le temps de raconter.
    </p>
  </section>
  <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-24">
    <SocialTabs client:load />
  </section>
</BaseLayout>
